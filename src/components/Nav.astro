---
const navLinks = [
  { label: 'Solutions', href: '/solutions', children: [
    { label: 'Digital Marketing', href: '/solutions/digital-marketing' },
    { label: 'Content Design', href: '/solutions/content-design' },
    { label: 'Website Development', href: '/solutions/website-development' },
    { label: 'Email Marketing', href: '/solutions/email-marketing' },
    { label: 'AI Workflows', href: '/solutions/ai-workflows' },
  ]},
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Pricing', href: '/pricing' },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" aria-label="Main navigation">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Squatch Marketing home">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue to-teal flex items-center justify-center transition-transform duration-300 group-hover:scale-110">
          <svg class="w-5 h-5 text-white" viewBox="0 0 24 28" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="12" cy="18" rx="7" ry="9.5"/>
            <circle cx="6" cy="5.5" r="2.2"/>
            <circle cx="10" cy="3" r="2"/>
            <circle cx="14.5" cy="3" r="2"/>
            <circle cx="18.5" cy="5.5" r="2.2"/>
            <circle cx="4" cy="9" r="1.8"/>
          </svg>
        </div>
        <span class="font-display font-700 text-[15px] text-white transition-colors duration-300">Squatch</span>
      </a>

      <!-- Desktop Links -->
      <div class="hidden lg:flex items-center gap-0.5">
        {navLinks.map((link) => (
          <div class="relative group">
            <a
              href={link.href}
              class="px-3.5 py-1.5 text-[13px] font-medium text-white/50 hover:text-white transition-colors duration-200 rounded-lg hover:bg-white/[0.03] flex items-center gap-1"
            >
              {link.label}
              {link.children && (
                <svg class="w-3 h-3 opacity-40 group-hover:opacity-80 transition-all duration-200 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {link.children && (
              <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0">
                <div class="bg-abyss/95 backdrop-blur-xl border border-white/[0.08] rounded-xl p-1.5 min-w-[200px] shadow-xl shadow-void/50">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-3.5 py-2 text-[13px] text-white/50 hover:text-white hover:bg-white/[0.04] rounded-lg transition-colors duration-150"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="hidden lg:block">
        <a href="/request-demo" class="btn-gradient px-5 py-2 rounded-xl text-[13px] font-semibold text-white inline-block">
          <span>Get Started</span>
        </a>
      </div>

      <!-- Mobile Menu Toggle -->
      <button id="mobile-toggle" class="lg:hidden text-white/60 p-1.5 -mr-1.5 hover:text-white transition-colors" aria-label="Toggle menu">
        <svg id="menu-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden">
    <div class="glass-strong mx-4 mb-4 rounded-xl p-3 space-y-0.5">
      {navLinks.map((link) => (
        <>
          <a href={link.href} class="block px-3.5 py-2.5 text-white/60 hover:text-white hover:bg-white/[0.04] rounded-lg transition-colors text-sm font-medium">
            {link.label}
          </a>
          {link.children && link.children.map((child) => (
            <a href={child.href} class="block px-7 py-2 text-white/35 hover:text-white hover:bg-white/[0.04] rounded-lg transition-colors text-sm">
              {child.label}
            </a>
          ))}
        </>
      ))}
      <div class="pt-2">
        <a href="/request-demo" class="btn-gradient block text-center px-5 py-2.5 rounded-xl text-sm font-semibold text-white">
          <span>Get Started</span>
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    const nav = document.getElementById('main-nav');
    const scrollHandler = () => {
      if (!nav) return;
      if (window.scrollY > 30) {
        nav.style.background = 'rgba(0,10,18,0.85)';
        nav.style.backdropFilter = 'blur(20px)';
        nav.style.webkitBackdropFilter = 'blur(20px)';
        nav.style.borderBottom = '1px solid rgba(255,255,255,0.04)';
      } else {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.webkitBackdropFilter = 'none';
        nav.style.borderBottom = '1px solid transparent';
      }
    };
    window.addEventListener('scroll', scrollHandler, { passive: true });
    scrollHandler();

    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-open');
    const iconClose = document.getElementById('menu-close');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
    });
  });
</script>
