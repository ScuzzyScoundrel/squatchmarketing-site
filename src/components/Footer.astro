---
const currentYear = new Date().getFullYear();
const solutions = [
  { label: 'Digital Marketing', href: '/solutions/digital-marketing' },
  { label: 'Content Design', href: '/solutions/content-design' },
  { label: 'Website Development', href: '/solutions/website-development' },
  { label: 'Email Marketing', href: '/solutions/email-marketing' },
  { label: 'AI Platform', href: '/solutions/ai-workflows' },
];
const company = [
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Request a Demo', href: '/request-demo' },
];
---

<footer class="relative bg-abyss overflow-hidden" role="contentinfo">
  <div class="section-divider"></div>
  <div class="noise absolute inset-0"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-5">
          <img src="/squatch-logo.svg" alt="Squatch Marketing" class="h-7 w-auto" />
        </a>
        <p class="text-white/25 text-sm leading-relaxed mb-6">
          Built in the mountains. Salt Lake City, Utah.
        </p>
        <div class="flex gap-2 mb-6">
          <a href="https://www.facebook.com/squatchmarketing" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg bg-white/[0.03] hover:bg-white/[0.08] flex items-center justify-center transition-colors duration-200 group" aria-label="Facebook">
            <svg class="w-3.5 h-3.5 text-white/25 group-hover:text-blue transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/squatchmarketing" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg bg-white/[0.03] hover:bg-white/[0.08] flex items-center justify-center transition-colors duration-200 group" aria-label="LinkedIn">
            <svg class="w-3.5 h-3.5 text-white/25 group-hover:text-blue transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>

        <!-- Newsletter -->
        <p class="text-white/35 text-xs font-medium mb-2">Stay in the loop</p>
        <iframe name="brevo-frame-footer" style="display:none"></iframe>
        <form id="footer-newsletter" method="POST" action="https://2d3a7fca.sibforms.com/serve/MUIFAEbhsZEod4saVXmJ1oCLhqkbYeTV-cI195a8uZwjHXOutGOdGkURiB7qajS0_ZjnrHk5Ecja3w_8IZ3J4SGHoxdcOLErcYuFKy755iBNlTn2g_h8HFA_5C758qSbXq0F6DfUYvLhRZOvK3fOKv68G7qK7OIjt5skb79fh6alyyBw7S-fCUx-WlA33QPBzgsFwfhjABAPJHKalQ==" target="brevo-frame-footer" class="flex gap-2">
          <input type="text" name="email_address_check" value="" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="locale" value="en" />
          <input type="hidden" name="html_type" value="simple" />
          <input
            type="email"
            name="EMAIL"
            required
            class="flex-1 min-w-0 px-3.5 py-2 bg-white/[0.03] border border-white/[0.06] rounded-lg text-white placeholder:text-white/20 text-xs focus:outline-none focus:border-blue/40 focus:bg-white/[0.05] transition-all duration-300"
            placeholder="you@company.com"
          />
          <button type="submit" class="btn-gradient px-4 py-2 rounded-lg text-white font-semibold text-xs whitespace-nowrap shrink-0">
            <span>Subscribe</span>
          </button>
        </form>
      </div>

      <!-- Solutions -->
      <nav aria-label="Solutions">
        <h4 class="font-display font-700 text-white/50 text-xs tracking-widest uppercase mb-5">Solutions</h4>
        <ul class="space-y-3">
          {solutions.map((link) => (
            <li>
              <a href={link.href} class="text-white/25 hover:text-teal text-sm transition-colors duration-200">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Company -->
      <nav aria-label="Company">
        <h4 class="font-display font-700 text-white/50 text-xs tracking-widest uppercase mb-5">Company</h4>
        <ul class="space-y-3">
          {company.map((link) => (
            <li>
              <a href={link.href} class="text-white/25 hover:text-teal text-sm transition-colors duration-200">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <h4 class="font-display font-700 text-white/50 text-xs tracking-widest uppercase mb-5">Contact</h4>
        <ul class="space-y-3 text-sm text-white/25">
          <li>
            <a href="tel:801-803-2136" class="hover:text-teal transition-colors duration-200">801-803-2136</a>
          </li>
          <li>
            <a href="mailto:marketing@squatchmarketing.com" class="hover:text-teal transition-colors duration-200 break-all">marketing@squatchmarketing.com</a>
          </li>
          <li class="leading-relaxed">
            West Valley City, Utah
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/[0.04] pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/15 text-xs">&copy; {currentYear} Squatch Marketing. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-white/15 hover:text-white/30 text-xs transition-colors">Privacy</a>
        <a href="/cookies" class="text-white/15 hover:text-white/30 text-xs transition-colors">Cookies</a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('footer-newsletter');
      if (!form) return;
      form.addEventListener('submit', () => {
        const btn = form.querySelector('button[type="submit"]');
        if (btn) btn.innerHTML = '<span>Sent!</span>';
        const input = form.querySelector('input[name="EMAIL"]');
        setTimeout(() => {
          if (input) input.value = '';
          if (btn) btn.innerHTML = '<span>Subscribe</span>';
        }, 2500);
      });
    });
  </script>
</footer>
