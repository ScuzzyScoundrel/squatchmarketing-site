---
// Curated grid of recent work — used as proof on paid landing + service pages.
// mode="all"    → 3 sites + 3 emails (default — for home + paid landings)
// mode="sites"  → 6 site previews    (for /solutions/website-development)
// mode="emails" → 6 email mockups    (for /solutions/email-marketing)
const { mode = 'all' } = Astro.props;

const sites = [
  { src: '/site-previews/nicks-tattoo.png',     label: "Nick's Tattoo",     industry: 'Tattoo Studio', kind: 'Website' },
  { src: '/site-previews/yogavega.png',         label: 'YogaVega',          industry: 'Yoga',          kind: 'Website' },
  { src: '/site-previews/blind-tiger.png',      label: 'Blind Tiger',       industry: 'Restaurant',    kind: 'Website' },
  { src: '/site-previews/ute-crossfit.png',     label: 'Ute CrossFit',      industry: 'Fitness',       kind: 'Website' },
  { src: '/site-previews/vision-re.png',        label: 'Vision Real Estate', industry: 'Real Estate',  kind: 'Website' },
  { src: '/site-previews/garcia-contracting.png', label: 'Garcia Contracting', industry: 'Trades',     kind: 'Website' },
];
const emails = [
  { src: '/work-screenshots/gym-challenge.png',          label: '30-Day Gym Challenge', industry: 'Fitness',      kind: 'Email' },
  { src: '/work-screenshots/chiropractic-recall.png',    label: 'Appointment Recall',   industry: 'Chiropractic', kind: 'Email' },
  { src: '/work-screenshots/restaurant-flash-event.png', label: 'Flash Event',          industry: 'Restaurant',   kind: 'Email' },
  { src: '/work-screenshots/medspa-welcome.png',         label: 'Welcome Series',       industry: 'Med Spa',      kind: 'Email' },
  { src: '/work-screenshots/dental-recall.png',          label: 'Cleaning Recall',      industry: 'Dental',       kind: 'Email' },
  { src: '/work-screenshots/real-estate-report.png',     label: 'Market Report',        industry: 'Real Estate',  kind: 'Email' },
];

const items = mode === 'sites'
  ? sites
  : mode === 'emails'
  ? emails
  : [...sites.slice(0, 3), ...emails.slice(0, 3)];

const heading = mode === 'sites'
  ? 'Real sites. Real businesses.'
  : mode === 'emails'
  ? 'Real campaigns. Real opens.'
  : 'Real businesses. Real results.';

const sub = mode === 'sites'
  ? 'A few preview sites we\'ve built for local businesses recently.'
  : mode === 'emails'
  ? 'A few email campaigns we\'ve designed for local businesses recently.'
  : 'A few recent sites and email campaigns we\'ve built for local businesses across Utah and beyond.';
---

<section class="relative py-24 bg-void overflow-hidden" aria-label="Recent work">
  <div class="orb-drift absolute top-[20%] left-[-5%] w-[400px] h-[400px] rounded-full bg-blue/[0.05] blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="reveal text-center max-w-2xl mx-auto mb-14">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12] mb-5">
        <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
        <span class="text-blue text-xs font-semibold tracking-wide">Recent Work</span>
      </div>
      <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight mb-4">
        {heading}
      </h2>
      <p class="text-white/40 text-base leading-relaxed">
        {sub}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((item, i) => (
        <div class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 5)}` : ''} glass-interactive rounded-2xl overflow-hidden group`}>
          <div class="relative aspect-[4/3] bg-deep overflow-hidden">
            <img
              src={item.src}
              alt={`${item.label} — ${item.industry}`}
              loading="lazy"
              class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
            />
          </div>
          <div class="p-5 flex items-center justify-between">
            <div>
              <div class="text-white text-sm font-semibold">{item.label}</div>
              <div class="text-white/30 text-xs mt-0.5">{item.industry}</div>
            </div>
            <span class="text-white/20 text-[11px] uppercase tracking-wide font-medium">
              {item.kind}
            </span>
          </div>
        </div>
      ))}
    </div>

    <div class="reveal text-center mt-12">
      <a href="/work" class="inline-flex items-center gap-2 text-blue hover:text-blue-light transition-colors text-sm font-semibold">
        <span>See all our work</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
