---
interface Props {
  title: string;
  description?: string;
  section?: string;
}
const { title, description = 'Clerri Marketing Strategy Hub — working document', section = '' } = Astro.props;

const navGroups = [
  {
    title: 'Start',
    items: [
      { slug: 'dashboard', href: '/clerri', label: 'Dashboard' },
    ],
  },
  {
    title: 'Strategy',
    items: [
      { slug: 'foundation', href: '/clerri/foundation', label: 'Strategic Foundation' },
      { slug: 'leadership-mandate', href: '/clerri/leadership-mandate', label: 'Leadership Mandate' },
      { slug: 'market', href: '/clerri/market', label: 'Market Context' },
      { slug: 'market-gaps', href: '/clerri/market-gaps', label: 'Market Gaps' },
      { slug: 'competitors', href: '/clerri/competitors', label: 'Competitor Intelligence' },
      { slug: 'clerri-weaknesses', href: '/clerri/clerri-weaknesses', label: "Clerri's Weaknesses" },
      { slug: 'icp', href: '/clerri/icp', label: 'ICP & ABM Targets' },
      { slug: 'segment-plan', href: '/clerri/segment-plan', label: 'Segment Marketing Plan' },
      { slug: 'patient-acquisition', href: '/clerri/patient-acquisition', label: 'Patient Acquisition' },
    ],
  },
  {
