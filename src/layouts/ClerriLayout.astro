    items: [
      { slug: 'ad-spend', href: '/clerri/ad-spend', label: 'Ad Spend Tiers' },
      { slug: 'zero-budget', href: '/clerri/zero-budget', label: 'Zero-Budget Strategy' },
      { slug: 'ad-strategy', href: '/clerri/ad-strategy', label: 'Ad Creative & Targeting' },
      { slug: 'messaging-playbook', href: '/clerri/messaging-playbook', label: 'Messaging Playbook' },
      { slug: 'content-ecosystem', href: '/clerri/content-ecosystem', label: 'Content Ecosystem' },
      { slug: 'linkedin-series', href: '/clerri/linkedin-series', label: 'LinkedIn Series · M1' },
      { slug: 'content-bank', href: '/clerri/content-bank', label: 'Content Bank' },
      { slug: 'aeo-seo', href: '/clerri/aeo-seo', label: 'AEO / SEO / SEM' },
      { slug: 'channels', href: '/clerri/channels', label: 'Channel Strategy' },
    ],
  },
  {
    title: 'Product & Web',
    items: [
      { slug: 'directory', href: '/clerri/directory', label: 'Patient Directory' },
      { slug: 'directory-mockup', href: '/clerri/directory-mockup', label: 'Directory Mockup' },
      { slug: 'website', href: '/clerri/website', label: 'Website & Messaging' },
      { slug: 'website-framework', href: '/clerri/website-framework', label: 'Website Framework' },
      { slug: 'website-build', href: '/clerri/website-build', label: 'Website Build & CMS' },
      { slug: 'product-ideas', href: '/clerri/product-ideas', label: 'Product Ideas' },
    ],
  },
  {
    title: 'AI & Tooling',
    items: [
      { slug: 'ai-stack', href: '/clerri/ai-stack', label: 'AI Marketing Stack' },
      { slug: 'workflows', href: '/clerri/workflows', label: 'Workflow Recipes' },
      { slug: 'claude-cli-vs-api', href: '/clerri/claude-cli-vs-api', label: 'Claude CLI vs API' },
      { slug: 'martech-audit', href: '/clerri/martech-audit', label: 'Martech Audit' },
      { slug: 'vendor-audit', href: '/clerri/vendor-audit', label: 'Vendor Audit' },
      { slug: 'reporting-automation', href: '/clerri/reporting-automation', label: 'Reporting Automation' },
