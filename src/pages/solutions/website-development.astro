---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Website Development" description="Custom website development by Squatch Marketing. Hand-coded, conversion-focused sites built with modern frameworks and AI-assisted workflows. Launch sites, business sites, and custom web apps.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[80vh] flex items-center gradient-mesh noise overflow-hidden" aria-label="Website Development Hero">
    <div class="orb-drift absolute top-[12%] left-[8%] w-[600px] h-[600px] rounded-full bg-blue/[0.09] blur-[150px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[5%] right-[-3%] w-[450px] h-[450px] rounded-full bg-teal/[0.07] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 lg:pt-44 pb-20">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
        <div>
          <div class="reveal mb-6">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12]">
              <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
              <span class="text-blue text-xs font-semibold tracking-wide">Custom Built</span>
            </div>
          </div>

          <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.02em] mb-7">
            Websites that<br />
            <span class="text-gradient">actually convert.</span>
          </h1>

          <p class="reveal reveal-delay-2 text-lg lg:text-xl text-white/35 leading-relaxed max-w-lg mb-10">
            Hand-coded with modern tools. Built fast with AI-assisted development. Designed around one goal: turning visitors into customers.
          </p>

          <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
            <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-xl text-white font-semibold text-[15px]">
              <span>Get a Quote</span>
            </a>
            <a href="/pricing" class="btn-ghost px-8 py-4 rounded-xl text-white/50 hover:text-white font-medium text-[15px]">
              View Pricing
            </a>
          </div>
        </div>

        <!-- Right: Browser window mockup -->
        <div class="hidden lg:block relative">
          <div class="glass-strong rounded-2xl p-1.5 glow relative">
            <div class="bg-abyss/90 rounded-xl overflow-hidden">
              <!-- Browser chrome -->
              <div class="flex items-center gap-2 px-5 py-3 border-b border-white/[0.05]">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="ml-4 flex-1 h-6 rounded-full bg-white/[0.04] flex items-center px-3">
                  <span class="text-[10px] text-white/20">https://yourcompany.com</span>
                </div>
              </div>
              <!-- Page content mockup — elements build in like assembling a site -->
              <div class="p-6 build-loop relative">
                <!-- Nav bar -->
                <div class="flex items-center justify-between mb-6">
                  <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded bg-gradient-to-br from-blue to-teal"></div>
                    <div class="h-2 w-16 rounded bg-white/[0.06]"></div>
                  </div>
                  <div class="flex gap-4">
                    <div class="h-2 w-10 rounded bg-white/[0.04]"></div>
                    <div class="h-2 w-10 rounded bg-white/[0.04]"></div>
                    <div class="h-2 w-10 rounded bg-white/[0.04]"></div>
                    <div class="h-5 w-14 rounded-xl bg-gradient-to-r from-blue/30 to-teal/25 btn-fake-hover"></div>
                  </div>
                </div>
                <!-- Hero area -->
                <div class="grid grid-cols-2 gap-6 mb-6">
                  <div class="space-y-3 py-4">
                    <div class="h-4 w-3/4 rounded bg-white/[0.08]"></div>
                    <div class="h-4 w-1/2 rounded bg-white/[0.06]"></div>
                    <div class="h-2.5 w-full rounded bg-white/[0.03] mt-4"></div>
                    <div class="h-2.5 w-5/6 rounded bg-white/[0.03]"></div>
                    <div class="h-8 w-24 rounded-xl bg-gradient-to-r from-blue/30 to-teal/25 mt-4 btn-fake-hover" style="animation-delay:1s"></div>
                  </div>
                  <div class="h-32 rounded-xl bg-gradient-to-br from-blue/[0.06] to-teal/[0.04] border border-white/[0.04] flex items-center justify-center">
                    <span class="text-xs text-white/15">Hero Image</span>
                  </div>
                </div>
                <!-- Fake cursor -->
                <div class="fake-cursor absolute top-24 left-12" style="--cx:120px;--cy:90px">
                  <svg viewBox="0 0 24 24" fill="white"><path d="M5.5 3.21V20.8c0 .45.54.67.85.35l4.86-4.86a.5.5 0 01.35-.15h6.87c.48 0 .68-.61.3-.91L5.93 2.92a.5.5 0 00-.43.29z"/></svg>
                </div>
                <!-- Analytics mini chart -->
                <div class="bg-white/[0.02] rounded-lg p-3 border border-white/[0.03]">
                  <div class="flex items-center justify-between mb-2">
                    <div class="h-2 w-14 rounded bg-white/[0.05]"></div>
                    <div class="text-[9px] text-teal font-medium">+24%</div>
                  </div>
                  <div class="flex items-end gap-1 h-10 bar-alive">
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-blue to-blue/40" style="height:35%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-blue to-blue/50" style="height:50%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-blue to-teal/40" style="height:42%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-teal/80 to-teal/40" style="height:68%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-teal to-teal/50" style="height:60%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-teal to-teal/40" style="height:82%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-teal to-blue/50" style="height:75%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-teal to-teal/60" style="height:95%"></div>
                    <div class="flex-1 rounded-sm bg-gradient-to-t from-teal to-teal/50" style="height:100%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Lighthouse score card -->
          <div class="absolute -bottom-6 -left-8 glass-strong rounded-xl p-4 glow z-10">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full border-2 border-teal flex items-center justify-center animate-pulse-glow">
                <span class="font-display font-800 text-teal text-sm">98</span>
              </div>
              <div>
                <div class="text-sm text-white font-semibold">Performance</div>
                <div class="text-xs text-white/35">Lighthouse Score</div>
              </div>
            </div>
          </div>
          <!-- Mobile responsive indicator -->
          <div class="absolute -top-4 -right-6 glass-strong rounded-xl p-3 glow z-10">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
              </svg>
              <span class="text-xs text-white/50 font-medium">Responsive</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== SCOPE TIERS ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Website scope tiers">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal max-w-2xl mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-5">
          Scoped to your goals. <span class="text-gradient">Built to perform.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Every project is different. We match the build to the scope, not the other way around. Modern frameworks, AI-assisted workflows, faster delivery.
        </p>
      </div>

      <!-- Tier cards -->
      <div class="grid lg:grid-cols-3 gap-6">
        <!-- Launch Sites -->
        <div class="reveal glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-blue/30"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-blue/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.841m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
            <div class="w-2 h-2 rounded-full bg-blue/40 animate-pulse-dot"></div>
          </div>
          <h3 class="font-display font-700 text-2xl text-white mb-2">Launch Sites</h3>
          <p class="text-ink text-sm leading-relaxed mb-6">Single-page builds for landing pages, product launches, and MVPs. Get online fast with a site that looks premium and converts from day one.</p>
          <ul class="space-y-2.5 mb-6">
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Conversion-focused layout
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Contact form integration
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Fast turnaround
            </li>
          </ul>
          <span class="text-xs px-3.5 py-1.5 rounded-full bg-blue/[0.06] text-blue/60 border border-blue/[0.08]">Landing pages &amp; MVPs</span>
        </div>

        <!-- Business Sites -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-9 relative overflow-hidden border-gradient">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue via-teal to-teal/30"></div>
          <div class="flex items-center gap-3 mb-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal/[0.08] border border-teal/[0.12]">
              <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse-dot"></span>
              <span class="text-teal text-xs font-semibold">Most Popular</span>
            </div>
          </div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-teal/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5M3.75 3v18m4.5-18v18m4.5-18v18m4.5-18v18M6 6.75h.008v.008H6V6.75zm0 3h.008v.008H6V9.75zm0 3h.008v.008H6v-.008zm0 3h.008v.008H6v-.008zm3-9h.008v.008H9V6.75zm0 3h.008v.008H9V9.75zm0 3h.008v.008H9v-.008zm0 3h.008v.008H9v-.008zm3-9h.008v.008H12V6.75zm0 3h.008v.008H12V9.75zm0 3h.008v.008H12v-.008zm3 0h.008v.008H15v-.008zm0 3h.008v.008H15v-.008z" />
              </svg>
            </div>
          </div>
          <h3 class="font-display font-700 text-2xl text-white mb-2">Business Sites</h3>
          <p class="text-ink text-sm leading-relaxed mb-6">Full multi-page websites for established businesses. Structured navigation, dedicated service pages, about sections, and lead generation funnels. The complete package.</p>
          <ul class="space-y-2.5 mb-6">
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Multi-page architecture
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              SEO-optimized structure
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Analytics and conversion tracking
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              CTA and funnel optimization
            </li>
          </ul>
          <span class="text-xs px-3.5 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">Full business presence</span>
        </div>

        <!-- Custom Projects -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal to-teal/30"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue/15 to-teal/15 flex items-center justify-center">
              <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
            </div>
            <div class="w-2 h-2 rounded-full bg-teal/40 animate-pulse-dot anim-delay-2"></div>
          </div>
          <h3 class="font-display font-700 text-2xl text-white mb-2">Custom Projects</h3>
          <p class="text-ink text-sm leading-relaxed mb-6">Complex builds that go beyond brochure sites. Web applications, e-commerce stores, client portals, booking systems. If it runs in a browser, we can build it.</p>
          <ul class="space-y-2.5 mb-6">
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Custom functionality
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              API integrations
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              E-commerce and payments
            </li>
            <li class="flex items-center gap-2.5 text-sm text-white/50">
              <svg class="w-4 h-4 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Database-driven features
            </li>
          </ul>
          <span class="text-xs px-3.5 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">Web apps &amp; e-commerce</span>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== ADD-ON SERVICES ========== -->
  <section class="relative py-28 section-mesh noise overflow-hidden" aria-label="Additional services">
    <div class="orb-drift absolute top-[15%] right-[8%] w-[400px] h-[400px] rounded-full bg-blue/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-6">
          Beyond the <span class="text-gradient">build.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Your site is live. Now what? We stick around.
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-6">
        <div class="reveal glass-interactive rounded-2xl p-10 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue/[0.03] to-transparent pointer-events-none"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
              </svg>
            </div>
            <h3 class="font-display font-700 text-xl text-white mb-3">Website Consulting</h3>
            <p class="text-ink text-[15px] leading-relaxed mb-5">Already have a site but it's not performing? We audit your current setup, identify conversion killers, and give you a prioritized fix list. One-time session or ongoing advisory.</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-3 py-1.5 rounded-full bg-blue/[0.06] text-blue/60 border border-blue/[0.08]">UX Audit</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-blue/[0.06] text-blue/60 border border-blue/[0.08]">Speed Audit</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-blue/[0.06] text-blue/60 border border-blue/[0.08]">SEO Review</span>
            </div>
          </div>
        </div>

        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-10 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-teal/[0.03] to-transparent pointer-events-none"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.159-5.159a2.25 2.25 0 010-3.182 2.25 2.25 0 013.182 0L12 9.386l2.557-2.557a2.25 2.25 0 013.182 0 2.25 2.25 0 010 3.182L11.42 15.17z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 12a9.75 9.75 0 11-19.5 0 9.75 9.75 0 0119.5 0z" />
              </svg>
            </div>
            <h3 class="font-display font-700 text-xl text-white mb-3">Website Maintenance</h3>
            <p class="text-ink text-[15px] leading-relaxed mb-5">Monthly retainer for content updates, security patches, performance monitoring, and uptime checks. We keep your site fast, secure, and current so you don't have to think about it.</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-3 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">Updates</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">Security</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">Monitoring</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== WHAT'S INCLUDED ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="What's included">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-6">
          Every site ships <span class="text-gradient">with these.</span>
        </h2>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="reveal glass rounded-2xl p-6 text-center">
          <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mx-auto mb-4">
