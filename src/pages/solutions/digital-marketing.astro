---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Digital Marketing" description="Paid social campaigns, retargeting ads, and digital marketing consulting from Squatch Marketing. We research your audience, analyze competitors, and optimize campaigns across Facebook, Instagram, LinkedIn, and Twitter.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[80vh] flex items-center gradient-mesh noise overflow-hidden" aria-label="Digital Marketing Hero">
    <div class="orb-drift absolute top-[8%] left-[5%] w-[600px] h-[600px] rounded-full bg-blue/[0.10] blur-[150px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[10%] right-[0%] w-[500px] h-[500px] rounded-full bg-teal/[0.06] blur-[130px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 lg:pt-44 pb-20">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
        <div>
          <div class="reveal mb-6">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12]">
              <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
              <span class="text-blue text-xs font-semibold tracking-wide">Performance Driven</span>
            </div>
          </div>

          <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.02em] mb-7">
            Campaigns that<br />
            <span class="text-gradient">pay for themselves.</span>
          </h1>

          <p class="reveal reveal-delay-2 text-lg lg:text-xl text-white/35 leading-relaxed max-w-lg mb-10">
            We research your audience, study your competitors, build conversion-focused ads, and optimize every dollar of your spend. No guesswork. Just performance.
          </p>

          <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
            <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-xl text-white font-semibold text-[15px]">
              <span>Start a Campaign</span>
            </a>
            <a href="/pricing" class="btn-ghost px-8 py-4 rounded-xl text-white/50 hover:text-white font-medium text-[15px]">
              View Pricing
            </a>
          </div>
        </div>

        <!-- Right: Campaign performance mockup -->
        <div class="hidden lg:block relative">
          <div class="glass-strong rounded-2xl p-1.5 glow relative">
            <div class="bg-abyss/90 rounded-xl overflow-hidden">
              <div class="flex items-center gap-2 px-6 py-3.5 border-b border-white/[0.05]">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <svg class="w-3 h-3 text-white/10" viewBox="0 0 24 28" fill="currentColor"><ellipse cx="12" cy="18" rx="7" ry="9.5"/><circle cx="6" cy="5.5" r="2.2"/><circle cx="10" cy="3" r="2"/><circle cx="14.5" cy="3" r="2"/><circle cx="18.5" cy="5.5" r="2.2"/><circle cx="4" cy="9" r="1.8"/></svg>
                <span class="ml-4 text-xs text-white/30 font-medium">Ad Performance</span>
              </div>
              <div class="p-6 space-y-5">
                <div class="grid grid-cols-3 gap-4">
                  <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04] metric-alive">
                    <div class="text-xs text-white/40 mb-2 font-medium">Ad Spend</div>
                    <div class="text-2xl font-display font-800 text-white leading-none">$8.4k</div>
                    <div class="text-xs text-blue mt-2 font-medium">This month</div>
                  </div>
                  <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04] metric-alive">
                    <div class="text-xs text-white/40 mb-2 font-medium">Revenue</div>
                    <div class="text-2xl font-display font-800 text-white leading-none">$38.2k</div>
                    <div class="text-xs text-teal mt-2 font-medium">+127%</div>
                  </div>
                  <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04] metric-alive">
                    <div class="text-xs text-white/40 mb-2 font-medium">ROAS</div>
                    <div class="text-2xl font-display font-800 text-gradient leading-none">4.5x</div>
                    <div class="text-xs text-teal mt-2 font-medium">+0.6x</div>
                  </div>
                </div>
                <!-- Platform breakdown -->
                <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04]">
                  <div class="text-xs text-white/40 mb-4 font-medium">Platform Breakdown</div>
                  <div class="space-y-3">
                    <div class="flex items-center gap-3">
                      <span class="text-xs text-white/50 w-20">Facebook</span>
                      <div class="flex-1 h-2 rounded-full bg-white/[0.04] overflow-hidden">
                        <div class="h-full rounded-full bg-gradient-to-r from-blue/60 to-blue/40 bar-shimmer" style="width:72%"></div>
                      </div>
                      <span class="text-xs text-blue font-medium">72%</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="text-xs text-white/50 w-20">Instagram</span>
                      <div class="flex-1 h-2 rounded-full bg-white/[0.04] overflow-hidden">
                        <div class="h-full rounded-full bg-gradient-to-r from-teal/60 to-teal/40 bar-shimmer" style="width:58%"></div>
                      </div>
                      <span class="text-xs text-teal font-medium">58%</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="text-xs text-white/50 w-20">LinkedIn</span>
                      <div class="flex-1 h-2 rounded-full bg-white/[0.04] overflow-hidden">
                        <div class="h-full rounded-full bg-gradient-to-r from-blue/50 to-teal/40 bar-shimmer" style="width:45%"></div>
                      </div>
                      <span class="text-xs text-white/40 font-medium">45%</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Floating conversion card -->
          <div class="absolute -bottom-6 -left-8 glass-strong rounded-xl p-4 w-52 glow z-10">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-teal/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                </svg>
              </div>
              <div>
                <div class="text-sm text-white font-semibold">CTR Up 34%</div>
                <div class="text-xs text-white/35">Last 7 days</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== WHAT WE DO ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Services overview">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal max-w-2xl mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-5">
          Full-funnel <span class="text-gradient">ad management.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          We don't just place ads. We build the entire system around them. Audience research, creative production, campaign architecture, and ongoing optimization.
        </p>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Social Ad Creation - wide -->
        <div class="reveal lg:col-span-2 glass-interactive rounded-2xl p-10 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue/[0.03] to-transparent pointer-events-none"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
              </svg>
            </div>
            <h3 class="font-display font-700 text-xl text-white mb-3">Social Ad Creation & Design</h3>
            <p class="text-ink text-[15px] leading-relaxed max-w-lg mb-6">We design scroll-stopping creatives tailored to each platform. Static images, carousels, video thumbnails. Every asset built to convert, not just look pretty.</p>
            <div class="flex flex-wrap gap-2">
              <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Static Ads</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Carousels</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Video Thumbnails</span>
              <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">A/B Variants</span>
            </div>
          </div>
        </div>

        <!-- Paid Campaigns -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-xl text-white mb-3">Paid Campaigns</h3>
          <p class="text-ink text-[15px] leading-relaxed mb-5">Facebook, Instagram, LinkedIn, Twitter. We handle campaign structure, budget allocation, audience targeting, and bid strategy.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-3 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">Meta</span>
            <span class="text-xs px-3 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">LinkedIn</span>
            <span class="text-xs px-3 py-1.5 rounded-full bg-teal/[0.06] text-teal/60 border border-teal/[0.08]">X/Twitter</span>
          </div>
        </div>

        <!-- Retargeting -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-xl text-white mb-3">Retargeting Ads</h3>
          <p class="text-ink text-[15px] leading-relaxed">Bring back visitors who didn't convert. We build pixel-based and list-based retargeting campaigns that re-engage warm audiences at the right moment.</p>
        </div>

        <!-- Consulting - wide bottom -->
        <div class="reveal reveal-delay-3 lg:col-span-2 glass-interactive rounded-2xl p-10 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-teal/[0.02] via-transparent to-blue/[0.02] pointer-events-none"></div>
          <div class="relative grid lg:grid-cols-[1fr_auto] gap-8 items-center">
            <div>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue/10 to-teal/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
                </svg>
              </div>
              <h3 class="font-display font-700 text-xl text-white mb-3">Digital Marketing Consulting</h3>
              <p class="text-ink text-[15px] leading-relaxed max-w-lg">Already have an in-house team? We audit your existing campaigns, identify wasted spend, and build a roadmap to better performance. Strategy sessions, competitive analysis, and ongoing advisory.</p>
            </div>
            <div class="hidden lg:flex flex-col gap-3">
              <div class="bg-white/[0.04] rounded-xl px-5 py-3 border border-white/[0.06] text-center">
                <span class="text-xs text-white/30 block mb-1">Avg. Waste Found</span>
                <span class="text-lg font-display font-800 text-gradient">23%</span>
              </div>
              <div class="bg-white/[0.04] rounded-xl px-5 py-3 border border-white/[0.06] text-center">
                <span class="text-xs text-white/30 block mb-1">Avg. ROAS Lift</span>
                <span class="text-lg font-display font-800 text-teal">+1.8x</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="relative py-28 section-mesh noise overflow-hidden" aria-label="Our process">
    <div class="orb-drift absolute top-[20%] right-[5%] w-[400px] h-[400px] rounded-full bg-blue/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center max-w-2xl mx-auto mb-20">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-6">
          How your campaigns <span class="text-gradient">come together.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Every engagement starts with research and ends with results. Here's the process.
        </p>
      </div>

      <div class="grid lg:grid-cols-4 gap-6">
        <div class="reveal glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-blue/30"></div>
          <div class="text-4xl font-display font-800 text-blue/15 mb-4">01</div>
          <h3 class="font-display font-700 text-white text-lg mb-3">Research</h3>
          <p class="text-ink text-sm leading-relaxed">Audience analysis, competitor audit, and market positioning. We learn your business before touching a single ad.</p>
        </div>

        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-teal/40"></div>
          <div class="text-4xl font-display font-800 text-blue/10 mb-4">02</div>
          <h3 class="font-display font-700 text-white text-lg mb-3">Create</h3>
          <p class="text-ink text-sm leading-relaxed">We design the creatives, write the copy, and build the campaign structure. You approve everything before launch.</p>
        </div>

        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal/30 to-teal/10"></div>
          <div class="text-4xl font-display font-800 text-teal/15 mb-4">03</div>
          <h3 class="font-display font-700 text-white text-lg mb-3">Launch</h3>
          <p class="text-ink text-sm leading-relaxed">Campaigns go live with proper tracking, attribution, and budget controls. We monitor performance from day one.</p>
        </div>

        <div class="reveal reveal-delay-3 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal via-blue/60 to-blue/30"></div>
          <div class="text-4xl font-display font-800 text-white/[0.06] mb-4">04</div>
          <h3 class="font-display font-700 text-white text-lg mb-3">Optimize</h3>
          <p class="text-ink text-sm leading-relaxed">Weekly reporting, A/B testing, budget reallocation. We double down on winners and kill underperformers fast.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== FAQ ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="FAQ">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-4xl text-white leading-tight mb-5">
          Common <span class="text-gradient">questions.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Straight answers. No runaround.
        </p>
      </div>

      <div class="space-y-4">
        <details class="reveal group glass rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer text-white font-display font-700 text-lg hover:text-blue transition-colors duration-200 list-none [&::-webkit-details-marker]:hidden">
            What platforms do you run campaigns on?
            <svg class="w-5 h-5 text-ink-muted shrink-0 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-6 pb-6 text-ink text-[15px] leading-relaxed border-t border-white/[0.04] pt-4">
            Facebook, Instagram, LinkedIn, and Twitter/X. We also manage Google Display campaigns when it makes sense for your audience. Most clients see the best results from Meta (Facebook + Instagram) for B2C and LinkedIn for B2B.
          </div>
        </details>

        <details class="reveal reveal-delay-1 group glass rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer text-white font-display font-700 text-lg hover:text-blue transition-colors duration-200 list-none [&::-webkit-details-marker]:hidden">
            What file formats do you deliver?
            <svg class="w-5 h-5 text-ink-muted shrink-0 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-6 pb-6 text-ink text-[15px] leading-relaxed border-t border-white/[0.04] pt-4">
            All ad creatives are delivered in platform-optimized formats. You get the source files (PSD, AI, or Figma), plus exported PNGs and JPGs at every required resolution. Video assets come as MP4. Everything is organized by platform and ad set.
          </div>
        </details>

        <details class="reveal reveal-delay-2 group glass rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer text-white font-display font-700 text-lg hover:text-blue transition-colors duration-200 list-none [&::-webkit-details-marker]:hidden">
            Can I hire you for just one campaign, or is it a package?
            <svg class="w-5 h-5 text-ink-muted shrink-0 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-6 pb-6 text-ink text-[15px] leading-relaxed border-t border-white/[0.04] pt-4">
            Both. We offer individual campaign engagements and monthly retainer packages. Single campaigns are great for testing the waters. Retainers give you ongoing optimization, creative refreshes, and better long-term results. We'll recommend what makes sense based on your goals and budget.
          </div>
        </details>

        <details class="reveal reveal-delay-3 group glass rounded-2xl overflow-hidden">
          <summary class="flex items-center justify-between p-6 cursor-pointer text-white font-display font-700 text-lg hover:text-blue transition-colors duration-200 list-none [&::-webkit-details-marker]:hidden">
            Who pays for the ad spend?
            <svg class="w-5 h-5 text-ink-muted shrink-0 transition-transform duration-300 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
          </summary>
          <div class="px-6 pb-6 text-ink text-[15px] leading-relaxed border-t border-white/[0.04] pt-4">
            You do. Ad spend goes directly to the platforms through your own ad accounts. Our fee covers strategy, creative, campaign management, and optimization. This keeps things transparent. You always own your accounts and data.
          </div>
        </details>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== CTA ========== -->
  <section class="relative py-36 bg-void overflow-hidden" aria-label="Call to action">
    <div class="orb-drift-reverse absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-blue/[0.05] blur-[160px] pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full bg-teal/[0.03] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-8 text-center">
      <h2 class="reveal font-display font-800 text-4xl lg:text-[3.25rem] text-white leading-tight mb-6">
        Stop guessing.<br /><span class="text-gradient">Start converting.</span>
      </h2>
      <p class="reveal reveal-delay-1 text-ink text-lg leading-relaxed max-w-lg mx-auto mb-12">
        Let's look at your current campaigns and find the opportunities you're leaving on the table. Free, no-pressure consultation.
      </p>
      <div class="reveal reveal-delay-2 flex flex-wrap justify-center gap-4">
