---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="AI Content Platform - Coming Soon" description="A custom AI content platform calibrated to your brand. Log in, pick an asset type, fill in a brief, get polished on-brand content instantly. Join the waitlist for early access.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[85vh] flex items-center gradient-mesh noise overflow-hidden" aria-label="Product Launch Hero">
    <div class="orb-drift absolute top-[3%] left-[-5%] w-[700px] h-[700px] rounded-full bg-teal/[0.10] blur-[170px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[0%] right-[-5%] w-[600px] h-[600px] rounded-full bg-blue/[0.08] blur-[150px] pointer-events-none"></div>
    <div class="orb-drift absolute top-[40%] left-[50%] w-[300px] h-[300px] rounded-full bg-teal/[0.05] blur-[100px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 lg:pt-44 pb-20">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
        <div>
          <div class="reveal mb-6">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
              <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
              <span class="text-teal text-xs font-semibold tracking-wide">Coming Soon</span>
            </div>
          </div>

          <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.02em] mb-7">
            Your brand.<br />
            Your content.<br />
            <span class="text-gradient">Instant.</span>
          </h1>

          <p class="reveal reveal-delay-2 text-lg lg:text-xl text-white/35 leading-relaxed max-w-lg mb-10">
            We're building a custom AI content platform calibrated to your brand. Log in, pick what you need, describe the campaign, and get polished, on-brand marketing assets in minutes.
          </p>

          <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
            <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-xl text-white font-semibold text-[15px]">
              <span>Join the Waitlist</span>
            </a>
          </div>

          <div class="reveal reveal-delay-4 mt-10 flex items-center gap-6">
            <div>
              <div class="text-2xl font-display font-800 text-gradient">10x</div>
              <div class="text-xs text-white/30">faster content production</div>
            </div>
            <div class="w-px h-10 bg-white/[0.06]"></div>
            <div>
              <div class="text-2xl font-display font-800 text-white">100%</div>
              <div class="text-xs text-white/30">on-brand output</div>
            </div>
          </div>
        </div>

        <!-- Right: AI terminal/platform mockup -->
        <div class="hidden lg:block relative">
          <div class="glass-strong rounded-2xl p-1.5 glow relative">
            <div class="bg-abyss/90 rounded-xl overflow-hidden">
              <!-- Terminal chrome -->
              <div class="flex items-center gap-2 px-6 py-3.5 border-b border-white/[0.05]">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <svg class="w-3 h-3 text-white/10" viewBox="0 0 24 28" fill="currentColor"><ellipse cx="12" cy="18" rx="7" ry="9.5"/><circle cx="6" cy="5.5" r="2.2"/><circle cx="10" cy="3" r="2"/><circle cx="14.5" cy="3" r="2"/><circle cx="18.5" cy="5.5" r="2.2"/><circle cx="4" cy="9" r="1.8"/></svg>
                <span class="ml-4 text-xs text-white/30 font-medium font-mono">brand-engine</span>
                <div class="ml-auto flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full bg-teal animate-pulse"></div>
                  <span class="text-[10px] text-teal font-mono">running</span>
                </div>
              </div>
              <!-- Terminal content -->
              <div class="p-5 font-mono text-sm space-y-3">
                <div class="flex items-start gap-2">
                  <span class="text-teal shrink-0">$</span>
                  <span class="text-white/60">generate <span class="text-blue">--brief</span> "Q2 product launch"</span>
                </div>
                <div class="pl-4 space-y-2 type-stagger">
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    <span class="text-white/40 text-xs">Loading brand profile... voice: <span class="text-teal">confident, technical</span></span>
                  </div>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    <span class="text-white/40 text-xs">Parsing brief... audience: <span class="text-teal">B2B SaaS</span></span>
                  </div>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    <span class="text-white/40 text-xs">Generating email sequence... <span class="text-teal">5 emails</span></span>
                  </div>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    <span class="text-white/40 text-xs">Generating social copy... <span class="text-blue">12 posts</span></span>
                  </div>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    <span class="text-white/40 text-xs">Landing page copy... <span class="text-blue">1 page</span></span>
                  </div>
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-teal shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                    <span class="text-white/40 text-xs">Brand voice check... <span class="text-teal">passed</span></span>
                  </div>
                </div>
                <div class="border-t border-white/[0.04] pt-3 mt-3">
                  <div class="flex items-center gap-2">
                    <span class="text-teal">&#10003;</span>
                    <span class="text-white/50 text-xs">Complete. <span class="text-teal font-semibold">19 assets</span> ready for review.</span>
                  </div>
                  <div class="text-white/20 text-xs mt-1">Elapsed: 2m 14s<span class="cursor-blink"></span></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Output summary floating card -->
          <div class="absolute -bottom-8 -left-10 glass-strong rounded-xl p-5 w-64 glow z-10">
            <div class="text-xs text-white/40 mb-3 font-semibold">Platform Output</div>
            <div class="space-y-2.5">
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs text-white/50">Emails</span>
                  <span class="text-xs text-teal font-semibold">5/5</span>
                </div>
                <div class="h-1.5 rounded-full bg-white/[0.04] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-teal to-teal/60 bar-shimmer" style="width:100%"></div>
                </div>
              </div>
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs text-white/50">Social Posts</span>
                  <span class="text-xs text-blue font-semibold">12/12</span>
                </div>
                <div class="h-1.5 rounded-full bg-white/[0.04] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-blue to-blue/60 bar-shimmer" style="width:100%"></div>
                </div>
              </div>
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs text-white/50">Landing Page</span>
                  <span class="text-xs text-white/40 font-semibold">1/1</span>
                </div>
                <div class="h-1.5 rounded-full bg-white/[0.04] overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-blue/60 to-teal/40 bar-shimmer" style="width:100%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Speed badge -->
          <div class="absolute -top-4 -right-6 glass-strong rounded-xl p-3 glow z-10">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
              <span class="text-xs text-white/50 font-semibold">10x Faster</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="How it works">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-5">
          How the <span class="text-gradient">platform works.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Three steps. From brand onboarding to finished content you can actually use.
        </p>
      </div>

      <div class="reveal max-w-4xl mx-auto">
        <div class="space-y-5">
          <!-- Step 1 -->
          <div class="glass-strong rounded-2xl p-7 border-l-[3px] border-l-blue/60 relative">
            <div class="absolute top-0 right-0 w-1/4 h-full bg-gradient-to-l from-blue/[0.03] to-transparent rounded-2xl pointer-events-none"></div>
            <div class="relative flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl bg-blue/20 flex items-center justify-center shrink-0">
                <span class="text-blue text-lg font-800 font-display">1</span>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-white text-lg font-display font-700">We learn your brand</span>
                </div>
                <p class="text-white/50 text-[15px] leading-relaxed">We study your voice, guidelines, audience, and competitors. We build a custom AI system around everything that makes you, you. The platform doesn't generate generic content. It generates your content.</p>
              </div>
            </div>
          </div>

          <!-- Connection -->
          <div class="flex justify-center">
            <div class="flex flex-col items-center gap-1">
              <div class="w-0.5 h-6 bg-gradient-to-b from-blue/30 to-teal/30 rounded-full animate-pulse-glow"></div>
              <svg class="w-4 h-4 text-white/15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" /></svg>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="glass-strong rounded-2xl p-7 border-l-[3px] border-l-teal/60 relative">
            <div class="absolute top-0 right-0 w-1/4 h-full bg-gradient-to-l from-teal/[0.03] to-transparent rounded-2xl pointer-events-none"></div>
            <div class="relative flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl bg-teal/20 flex items-center justify-center shrink-0">
                <span class="text-teal text-lg font-800 font-display">2</span>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-white text-lg font-display font-700">You submit a brief</span>
                </div>
                <p class="text-white/50 text-[15px] leading-relaxed">Log into your portal. Pick what you need: email, social, landing page, ad copy. Describe the campaign in plain English. That's it.</p>
              </div>
            </div>
          </div>

          <!-- Connection -->
          <div class="flex justify-center">
            <div class="flex flex-col items-center gap-1">
              <div class="w-0.5 h-6 bg-gradient-to-b from-teal/30 to-blue/30 rounded-full animate-pulse-glow"></div>
              <svg class="w-4 h-4 text-white/15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" /></svg>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="glass-strong rounded-2xl p-7 border-l-[3px] border-l-teal/60 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-teal/[0.02] via-transparent to-blue/[0.02] pointer-events-none"></div>
            <div class="relative flex items-start gap-5">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal/20 to-blue/20 flex items-center justify-center shrink-0">
                <span class="text-teal text-lg font-800 font-display">3</span>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-white text-lg font-display font-700">Get instant, on-brand content</span>
                </div>
                <p class="text-white/50 text-[15px] leading-relaxed">The platform generates polished, ready-to-use assets that sound like your best copywriter wrote them. Review, edit, deploy.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== WHAT YOU'LL GET ========== -->
  <section class="relative py-28 section-mesh noise overflow-hidden" aria-label="Asset types">
    <div class="orb-drift absolute top-[10%] right-[5%] w-[500px] h-[500px] rounded-full bg-teal/[0.05] blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-5">
          What you'll <span class="text-gradient">get.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          One platform. Every content type your marketing needs. All calibrated to your brand.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
        <!-- Email Sequences -->
        <div class="reveal glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-2">Email Sequences</h3>
          <p class="text-ink text-sm leading-relaxed">Welcome series, nurture flows, promotional campaigns. Subject lines, preview text, body copy, CTAs. Ready to drop into your ESP.</p>
        </div>

        <!-- Social Media Posts -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-2">Social Media Posts</h3>
          <p class="text-ink text-sm leading-relaxed">Platform-native posts for LinkedIn, X, Facebook, and Instagram. Adapted tone and format for each channel. Captions and hashtags included.</p>
        </div>

        <!-- Landing Page Copy -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-2">Landing Page Copy</h3>
          <p class="text-ink text-sm leading-relaxed">Headlines, subheads, body sections, CTAs, and social proof blocks. Conversion-focused copy structured for your page layout.</p>
        </div>

        <!-- Ad Copy -->
        <div class="reveal reveal-delay-3 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-2">Ad Copy</h3>
          <p class="text-ink text-sm leading-relaxed">Headlines, descriptions, and creative briefs for paid campaigns. Multiple variants per ad set for testing. Platform-optimized for Google, Meta, and LinkedIn.</p>
        </div>

        <!-- Blog Content -->
        <div class="reveal reveal-delay-4 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="w-10 h-10 rounded-lg bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-2">Blog Content</h3>
          <p class="text-ink text-sm leading-relaxed">SEO-optimized blog posts, thought leadership articles, and long-form content. Outlines, drafts, and polished finals in your brand voice.</p>
        </div>

        <!-- Brand Collateral -->
        <div class="reveal reveal-delay-5 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue/10 to-teal/10 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-2">Brand Collateral</h3>
          <p class="text-ink text-sm leading-relaxed">One-pagers, case study drafts, pitch decks, sales enablement copy. Anything your team sends externally, written in one consistent voice.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== EARLY ACCESS ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Early access">
    <div class="orb-drift-reverse absolute top-[20%] left-[10%] w-[400px] h-[400px] rounded-full bg-blue/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8">
      <div class="reveal glass-strong rounded-3xl p-10 lg:p-14 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-teal/[0.03] via-transparent to-blue/[0.03] pointer-events-none"></div>
        <div class="noise absolute inset-0 rounded-3xl"></div>

        <div class="relative z-10 max-w-2xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12] mb-8">
            <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
            <span class="text-teal text-xs font-semibold tracking-wide">Limited Early Access</span>
          </div>

          <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-6">
            We're onboarding brands <span class="text-gradient">one at a time.</span>
          </h2>
