---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Solutions" description="Explore Squatch Marketing's full-service solutions — digital marketing, content design, website development, and email marketing campaigns tailored to grow your business.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[70vh] flex items-center gradient-mesh noise overflow-hidden">
    <!-- Floating orbs -->
    <div class="orb-1 absolute top-1/4 left-[10%] w-[500px] h-[500px] rounded-full bg-blue/10 blur-[120px] pointer-events-none"></div>
    <div class="orb-2 absolute bottom-1/4 right-[5%] w-[400px] h-[400px] rounded-full bg-teal/8 blur-[100px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-20">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <div class="reveal flex items-center gap-3 mb-8">
          <div class="h-px w-12 bg-gradient-to-r from-blue to-teal"></div>
          <span class="text-teal text-sm font-medium tracking-widest uppercase">What We Offer</span>
        </div>

        <!-- Headline -->
        <h1 class="reveal reveal-delay-1 font-display font-800 text-5xl sm:text-6xl lg:text-7xl text-white leading-[1.05] tracking-tight mb-8">
          Our <span class="text-gradient">Solutions</span>
        </h1>

        <!-- Subtitle -->
        <p class="reveal reveal-delay-2 text-lg sm:text-xl text-white/50 leading-relaxed max-w-xl mb-12">
          Full-service marketing built around your goals. From paid campaigns to custom websites, we bring strategy and execution under one roof.
        </p>

        <!-- CTA -->
        <div class="reveal reveal-delay-3 flex flex-wrap gap-4">
          <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-full text-white font-semibold text-sm tracking-wide">
            <span>Request a Demo</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SOLUTIONS GRID ========== -->
  <section class="relative py-32 bg-white overflow-hidden">
    <!-- Subtle background accent -->
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-surface to-transparent pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Section header -->
      <div class="max-w-2xl mb-20">
        <div class="reveal flex items-center gap-3 mb-4">
          <div class="h-px w-12 bg-gradient-to-r from-blue to-teal"></div>
          <span class="text-blue text-sm font-medium tracking-widest uppercase">Our Capabilities</span>
        </div>
        <h2 class="reveal reveal-delay-1 font-display font-800 text-4xl lg:text-5xl text-navy leading-tight mb-6">
          Four pillars of <span class="text-gradient">real growth</span>
        </h2>
        <p class="reveal reveal-delay-2 text-ink-muted text-lg leading-relaxed">
          Each solution is designed to work on its own or together as a unified strategy. Pick what you need, or let us build the full picture.
        </p>
      </div>

      <!-- Solution cards — 2-column grid, larger format -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Digital Marketing -->
        <a href="/solutions/digital-marketing" class="reveal group relative rounded-3xl p-10 lg:p-12 bg-white border border-navy/5 hover:border-blue/20 transition-all duration-500 hover:shadow-xl hover:shadow-blue/5 hover:-translate-y-1">
          <div class="flex items-start justify-between mb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue/10 to-teal/10 flex items-center justify-center group-hover:from-blue/20 group-hover:to-teal/20 transition-colors duration-500">
              <svg class="w-8 h-8 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
              </svg>
            </div>
            <svg class="w-5 h-5 text-ink-muted/30 group-hover:text-blue group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-2xl text-navy mb-4 group-hover:text-blue transition-colors duration-300">Digital Marketing</h3>
          <p class="text-ink-muted text-base leading-relaxed mb-6">
            Drive qualified traffic and turn clicks into customers with data-backed campaigns across every major platform.
          </p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Social ad creation &amp; management
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Paid search &amp; display campaigns
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Retargeting &amp; audience segmentation
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Cross-channel online strategies
            </li>
          </ul>
        </a>

        <!-- Content Design -->
        <a href="/solutions/content-design" class="reveal reveal-delay-1 group relative rounded-3xl p-10 lg:p-12 bg-white border border-navy/5 hover:border-teal/20 transition-all duration-500 hover:shadow-xl hover:shadow-teal/5 hover:-translate-y-1">
          <div class="flex items-start justify-between mb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal/10 to-blue/10 flex items-center justify-center group-hover:from-teal/20 group-hover:to-blue/20 transition-colors duration-500">
              <svg class="w-8 h-8 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
              </svg>
            </div>
            <svg class="w-5 h-5 text-ink-muted/30 group-hover:text-teal group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-2xl text-navy mb-4 group-hover:text-teal transition-colors duration-300">Content Design</h3>
          <p class="text-ink-muted text-base leading-relaxed mb-6">
            Compelling visual content that tells your story, builds authority, and leaves a lasting impression on your audience.
          </p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Infographics &amp; data visualization
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Whitepapers &amp; case studies
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Brand books &amp; style guides
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Trade-show &amp; print materials
            </li>
          </ul>
        </a>

        <!-- Website Development -->
        <a href="/solutions/website-development" class="reveal group relative rounded-3xl p-10 lg:p-12 bg-white border border-navy/5 hover:border-blue/20 transition-all duration-500 hover:shadow-xl hover:shadow-blue/5 hover:-translate-y-1">
          <div class="flex items-start justify-between mb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue/10 to-teal/10 flex items-center justify-center group-hover:from-blue/20 group-hover:to-teal/20 transition-colors duration-500">
              <svg class="w-8 h-8 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
            </div>
            <svg class="w-5 h-5 text-ink-muted/30 group-hover:text-blue group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-2xl text-navy mb-4 group-hover:text-blue transition-colors duration-300">Website Development</h3>
          <p class="text-ink-muted text-base leading-relaxed mb-6">
            Custom-built websites engineered to convert visitors into customers, with performance and SEO baked in from day one.
          </p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              New development &amp; full redesigns
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Conversion-optimized landing pages
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Responsive &amp; mobile-first design
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Performance &amp; SEO optimization
            </li>
          </ul>
        </a>

        <!-- Email Marketing -->
        <a href="/solutions/email-marketing" class="reveal reveal-delay-1 group relative rounded-3xl p-10 lg:p-12 bg-white border border-navy/5 hover:border-teal/20 transition-all duration-500 hover:shadow-xl hover:shadow-teal/5 hover:-translate-y-1">
          <div class="flex items-start justify-between mb-8">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-teal/10 to-blue/10 flex items-center justify-center group-hover:from-teal/20 group-hover:to-blue/20 transition-colors duration-500">
              <svg class="w-8 h-8 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <svg class="w-5 h-5 text-ink-muted/30 group-hover:text-teal group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-2xl text-navy mb-4 group-hover:text-teal transition-colors duration-300">Email Marketing</h3>
          <p class="text-ink-muted text-base leading-relaxed mb-6">
            End-to-end email programs that nurture leads, retain customers, and drive measurable revenue with every send.
          </p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              ESP selection &amp; platform setup
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Email branding &amp; template design
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              List cleaning &amp; deliverability
            </li>
            <li class="flex items-center gap-2 text-sm text-ink-muted">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Campaign strategy &amp; automation
            </li>
          </ul>
        </a>

      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="relative py-32 bg-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-surface via-white to-surface pointer-events-none"></div>

    <div class="relative max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <div class="reveal">
        <div class="flex items-center justify-center gap-3 mb-4">
          <div class="h-px w-12 bg-gradient-to-r from-blue to-teal"></div>
          <span class="text-blue text-sm font-medium tracking-widest uppercase">Get Started</span>
          <div class="h-px w-12 bg-gradient-to-l from-blue to-teal"></div>
        </div>
      </div>

      <h2 class="reveal reveal-delay-1 font-display font-800 text-4xl lg:text-5xl text-navy leading-tight mb-6">
        Ready to <span class="text-gradient">get started</span>?
      </h2>
      <p class="reveal reveal-delay-2 text-ink-muted text-lg leading-relaxed max-w-2xl mx-auto mb-10">
        Tell us where you want to grow and we'll build a plan that fits. No cookie-cutter packages — just strategy shaped around your business.
      </p>
      <div class="reveal reveal-delay-3 flex flex-wrap justify-center gap-4">
        <a href="/request-demo" class="btn-gradient px-10 py-4 rounded-full text-white font-semibold text-sm tracking-wide">
          <span>Request a Demo</span>
        </a>
        <a href="/pricing" class="px-10 py-4 rounded-full text-navy font-semibold text-sm tracking-wide border border-navy/10 hover:border-navy/30 hover:bg-navy/5 transition-all duration-300">
          View Pricing
        </a>
      </div>
    </div>
  </section>

</Layout>
