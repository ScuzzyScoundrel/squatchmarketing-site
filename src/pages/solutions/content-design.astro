---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Content Design" description="Brand identity, infographics, whitepapers, case studies, swag design, and tradeshow graphics from Squatch Marketing. AI-assisted workflows deliver production-ready assets fast.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[80vh] flex items-center gradient-mesh noise overflow-hidden" aria-label="Content Design Hero">
    <div class="orb-drift absolute top-[5%] right-[10%] w-[550px] h-[550px] rounded-full bg-teal/[0.08] blur-[140px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[15%] left-[0%] w-[500px] h-[500px] rounded-full bg-blue/[0.06] blur-[130px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 lg:pt-44 pb-20">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
        <div>
          <div class="reveal mb-6">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
              <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
              <span class="text-teal text-xs font-semibold tracking-wide">AI-Assisted</span>
            </div>
          </div>

          <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.02em] mb-7">
            Design that <br />
            <span class="text-gradient">earns attention.</span>
          </h1>

          <p class="reveal reveal-delay-2 text-lg lg:text-xl text-white/35 leading-relaxed max-w-lg mb-10">
            From brand identity to tradeshow booths. We create visual assets that communicate clearly and look sharp at every touchpoint. Faster than you thought possible.
          </p>

          <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
            <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-xl text-white font-semibold text-[15px]">
              <span>Start a Project</span>
            </a>
            <a href="/pricing" class="btn-ghost px-8 py-4 rounded-xl text-white/50 hover:text-white font-medium text-[15px]">
              View Pricing
            </a>
          </div>

          <div class="reveal reveal-delay-4 mt-10 flex items-center gap-6">
            <div>
              <div class="text-2xl font-display font-800 text-gradient">3x</div>
              <div class="text-xs text-white/30">faster delivery with AI</div>
            </div>
            <div class="w-px h-10 bg-white/[0.06]"></div>
            <div>
              <div class="text-2xl font-display font-800 text-white">94%</div>
              <div class="text-xs text-white/30">judge credibility by design</div>
            </div>
          </div>
        </div>

        <!-- Right: Brand collateral mockup -->
        <div class="hidden lg:block relative">
          <div class="relative space-y-4">
            <!-- Brand book mockup — sections assemble -->
            <div class="glass-strong rounded-2xl p-6 glow build-stagger">
              <div class="flex items-center gap-4 mb-5">
                <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue to-teal flex items-center justify-center">
                  <svg class="w-6 h-6 text-white" viewBox="0 0 24 28" fill="currentColor"><ellipse cx="12" cy="18" rx="7" ry="9.5"/><circle cx="6" cy="5.5" r="2.2"/><circle cx="10" cy="3" r="2"/><circle cx="14.5" cy="3" r="2"/><circle cx="18.5" cy="5.5" r="2.2"/><circle cx="4" cy="9" r="1.8"/></svg>
                </div>
                <div>
                  <div class="h-3 w-32 rounded bg-white/[0.08]"></div>
                  <div class="h-2 w-20 rounded bg-white/[0.04] mt-2"></div>
                </div>
                <div class="ml-auto w-2 h-2 rounded-full bg-teal/60 animate-pulse-dot"></div>
              </div>
              <!-- Color palette -->
              <div class="flex gap-2 mb-5">
                <div class="flex-1 h-10 rounded-lg bg-gradient-to-br from-blue to-blue/80 color-alive"></div>
                <div class="flex-1 h-10 rounded-lg bg-gradient-to-br from-teal to-teal/80 color-alive"></div>
                <div class="flex-1 h-10 rounded-lg bg-navy color-alive"></div>
                <div class="flex-1 h-10 rounded-lg bg-white/10 color-alive"></div>
                <div class="flex-1 h-10 rounded-lg bg-slate color-alive"></div>
              </div>
              <!-- Typography preview -->
              <div class="grid grid-cols-2 gap-3">
                <div class="bg-white/[0.03] rounded-lg p-3 border border-white/[0.04]">
                  <div class="text-[10px] text-white/30 mb-1">Display</div>
                  <div class="font-display font-800 text-white text-lg">Syne Bold</div>
                </div>
                <div class="bg-white/[0.03] rounded-lg p-3 border border-white/[0.04]">
                  <div class="text-[10px] text-white/30 mb-1">Body</div>
                  <div class="text-white text-base">DM Sans Regular</div>
                </div>
              </div>
            </div>

            <!-- Floating infographic card -->
            <div class="absolute -bottom-4 -right-6 glass-strong rounded-xl p-4 w-52 glow z-10">
              <div class="text-xs text-white/40 mb-2 font-medium">Engagement Metrics</div>
              <div class="flex items-end gap-1.5 h-16 bar-alive">
                <div class="flex-1 rounded bg-gradient-to-t from-teal to-teal/40" style="height:40%"></div>
                <div class="flex-1 rounded bg-gradient-to-t from-teal to-teal/50" style="height:65%"></div>
                <div class="flex-1 rounded bg-gradient-to-t from-blue to-blue/40" style="height:50%"></div>
                <div class="flex-1 rounded bg-gradient-to-t from-blue to-blue/50" style="height:80%"></div>
                <div class="flex-1 rounded bg-gradient-to-t from-blue to-teal/60" style="height:100%"></div>
                <div class="flex-1 rounded bg-gradient-to-t from-teal to-teal/50" style="height:72%"></div>
                <div class="flex-1 rounded bg-gradient-to-t from-teal to-blue/50" style="height:88%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== SERVICE PACKAGES ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Content packages">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal max-w-2xl mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-5">
          Everything your brand <span class="text-gradient">needs to show up.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Five categories of content, all built around your brand. Pick one or combine them. Every project delivers production-ready assets you can use immediately.
        </p>
      </div>

      <!-- Package cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Digital Content -->
        <div class="reveal glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-blue/30"></div>
          <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-xl text-white mb-3">Digital Content</h3>
          <p class="text-ink text-[15px] leading-relaxed mb-5">Logo design, branding packages, brand books, social media graphics, and digital infographics. Built for screens.</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 animate-pulse-dot shrink-0"></div>
              Logo &amp; brand identity
            </li>
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Brand books &amp; style guides
            </li>
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Digital infographics
            </li>
          </ul>
        </div>

        <!-- Print Content -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal to-teal/30"></div>
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-xl text-white mb-3">Print Content</h3>
          <p class="text-ink text-[15px] leading-relaxed mb-5">Whitepapers, case studies, product overview sheets, and tradeshow booth designs. Print-ready files with bleed and crop marks included.</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 animate-pulse-dot anim-delay-1 shrink-0"></div>
              Whitepapers &amp; case studies
            </li>
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Tradeshow booth graphics
            </li>
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-teal/40 shrink-0"></div>
              Product overview sheets
            </li>
          </ul>
        </div>

        <!-- Internal Documents -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-teal/40"></div>
          <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-xl text-white mb-3">Internal Documents</h3>
          <p class="text-ink text-[15px] leading-relaxed mb-5">Branded templates for presentations, reports, proposals, and internal communications. Your team looks polished every time.</p>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Presentation decks
            </li>
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Report templates
            </li>
            <li class="flex items-center gap-2 text-sm text-white/50">
              <div class="w-1.5 h-1.5 rounded-full bg-blue/40 shrink-0"></div>
              Proposal layouts
            </li>
          </ul>
        </div>

        <!-- Swag - wide -->
        <div class="reveal reveal-delay-3 lg:col-span-2 glass-interactive rounded-2xl p-10 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-teal/[0.02] via-transparent to-blue/[0.02] pointer-events-none"></div>
          <div class="relative grid lg:grid-cols-[1fr_auto] gap-8 items-start">
            <div>
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-teal/10 to-blue/10 flex items-center justify-center mb-5">
                <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                </svg>
              </div>
              <h3 class="font-display font-700 text-xl text-white mb-3">Swag &amp; Branded Merchandise</h3>
              <p class="text-ink text-[15px] leading-relaxed max-w-lg mb-5">T-shirts, stickers, mugs, pens, tote bags. We design the artwork and deliver production-ready files. You choose your printer or we'll recommend one.</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">T-Shirts</span>
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Stickers</span>
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Mugs</span>
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Tote Bags</span>
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Custom</span>
              </div>
            </div>
            <!-- Swag visual -->
            <div class="hidden lg:flex flex-col gap-3 items-center">
              <div class="bg-white/[0.04] rounded-xl p-4 border border-white/[0.06] w-36 text-center">
                <div class="w-16 h-16 mx-auto rounded-xl bg-gradient-to-br from-blue/15 to-teal/15 flex items-center justify-center mb-2">
                  <span class="font-display font-800 text-gradient text-2xl">S</span>
                </div>
                <div class="text-xs text-white/30">Branded Tee</div>
              </div>
              <div class="bg-white/[0.04] rounded-xl p-4 border border-white/[0.06] w-36 text-center">
                <div class="w-16 h-10 mx-auto rounded-lg bg-gradient-to-r from-blue/20 to-teal/20 flex items-center justify-center mb-2">
                  <span class="font-display font-800 text-white/40 text-sm">STICKER</span>
                </div>
                <div class="text-xs text-white/30">Die-Cut Sticker</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Custom Requests -->
        <div class="reveal reveal-delay-4 glass-interactive rounded-2xl p-9 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal via-blue/60 to-blue/30"></div>
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-xl text-white mb-3">Custom Requests</h3>
          <p class="text-ink text-[15px] leading-relaxed">Need something that doesn't fit a category? Pitch decks, annual reports, event signage, vehicle wraps. If it's visual, we design it.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="relative py-28 section-mesh noise overflow-hidden" aria-label="How it works">
    <div class="orb-drift absolute top-[10%] left-[5%] w-[400px] h-[400px] rounded-full bg-teal/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-6">
          Built for <span class="text-gradient">speed.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          AI-assisted workflows let us move faster without cutting corners. You get better work in less time.
        </p>
      </div>

      <div class="grid lg:grid-cols-4 gap-6">
        <!-- Step 1 -->
        <div class="reveal glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-blue/30"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-full bg-blue/10 flex items-center justify-center">
              <span class="font-display font-800 text-blue text-sm">01</span>
            </div>
            <div class="h-px flex-1 bg-gradient-to-r from-blue/20 to-transparent"></div>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-3">Brief</h3>
          <p class="text-ink text-sm leading-relaxed">You tell us what you need. We ask the right questions. No 40-page intake forms.</p>
        </div>

        <!-- Step 2 -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue to-teal/40"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-full bg-blue/10 flex items-center justify-center">
              <span class="font-display font-800 text-blue text-sm">02</span>
            </div>
            <div class="h-px flex-1 bg-gradient-to-r from-blue/20 to-transparent"></div>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-3">Create</h3>
          <p class="text-ink text-sm leading-relaxed">We combine creative direction with AI-assisted production. Concepts come together fast. Quality stays high.</p>
        </div>

        <!-- Step 3 -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal to-teal/30"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-full bg-teal/10 flex items-center justify-center">
              <span class="font-display font-800 text-teal text-sm">03</span>
            </div>
            <div class="h-px flex-1 bg-gradient-to-r from-teal/20 to-transparent"></div>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-3">Revise</h3>
          <p class="text-ink text-sm leading-relaxed">You review. We refine. Every project includes revision rounds so the output matches your vision exactly.</p>
        </div>

        <!-- Step 4 -->
        <div class="reveal reveal-delay-3 glass-interactive rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-teal to-blue/40"></div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-full bg-teal/10 flex items-center justify-center">
              <span class="font-display font-800 text-teal text-sm">04</span>
            </div>
            <div class="h-px flex-1 bg-gradient-to-r from-teal/20 to-transparent"></div>
            <div class="w-2 h-2 rounded-full bg-teal/60 animate-pulse-glow"></div>
          </div>
          <h3 class="font-display font-700 text-lg text-white mb-3">Deliver</h3>
          <p class="text-ink text-sm leading-relaxed">Production-ready exports in every format you need. Organized, labeled, ready to use the moment you download.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== WHAT YOU GET ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Deliverables">
