---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: 'Digital Marketing',
    description: 'Paid ads, SEO, social media, and analytics. We build campaigns that bring qualified traffic and convert it into revenue.',
    icon: 'chart',
    color: 'blue',
  },
  {
    title: 'Content Design',
    description: 'Brand identity, graphics, video, and creative assets that make people stop scrolling. Consistent, polished, on-brand.',
    icon: 'palette',
    color: 'teal',
  },
  {
    title: 'Website Development',
    description: 'Fast, modern websites that look great and actually convert. Built with clean code and designed around your customers.',
    icon: 'code',
    color: 'blue',
  },
  {
    title: 'Email Marketing',
    description: 'Sequences, newsletters, and automations that land in inboxes and drive action. Not spam. Strategic communication.',
    icon: 'mail',
    color: 'teal',
  },
  {
    title: 'AI Workflows',
    badge: 'New',
    description: 'Automate the repetitive stuff. AI-powered content generation, data analysis, and workflow optimization that saves hours every week.',
    icon: 'spark',
    color: 'blue',
  },
];

const reasons = [
  {
    title: 'Your business is unique',
    description: 'A local bakery and a SaaS startup have completely different needs. Why would they pay the same price for the same package?',
  },
  {
    title: 'Scope changes everything',
    description: 'A single landing page and a 50-page website are different projects. We price based on what you actually need, not what fits a spreadsheet.',
  },
  {
    title: 'You only pay for what you use',
    description: 'No bloated bundles where you pay for services you never touch. Every dollar goes toward work that moves your business forward.',
  },
  {
    title: 'We scale with you',
    description: 'Start small. See results. Grow from there. Your marketing investment should match your growth stage, not the other way around.',
  },
];
---

<Layout
  title="Pricing"
  description="Squatch Marketing offers custom pricing based on your business needs. No cookie-cutter packages. Get a free consultation and a quote tailored to your goals."
>

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[70vh] flex items-center gradient-mesh noise overflow-hidden" aria-label="Pricing Hero">
    <div class="orb-drift absolute top-[10%] left-[5%] w-[600px] h-[600px] rounded-full bg-blue/[0.08] blur-[160px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[5%] right-[0%] w-[500px] h-[500px] rounded-xl bg-teal/[0.06] blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 lg:pt-44 pb-24">
      <div class="max-w-3xl">
        <div class="reveal">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
              <div class="w-1.5 h-1.5 rounded-xl bg-teal animate-pulse"></div>
              <span class="text-teal text-xs font-semibold tracking-wide">Transparent Pricing</span>
            </div>
          </div>
        <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.03em] mb-7">
          Fair pricing.<br />
          <span class="text-gradient">No surprises.</span>
        </h1>
        <p class="reveal reveal-delay-2 text-lg lg:text-xl text-white/35 leading-relaxed max-w-2xl mb-10">
          We don't do cookie-cutter packages. Every business is different, so every quote is built around what you actually need. No upsells. No hidden fees. Just honest pricing for real work.
        </p>
        <div class="reveal reveal-delay-3 flex flex-wrap gap-3">
          <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-xl text-white font-semibold text-[15px]">
            <span>Get Your Free Quote</span>
          </a>
          <a href="tel:801-803-2136" class="btn-ghost px-8 py-4 rounded-xl text-white/50 hover:text-white font-medium text-[15px]">
            Call 801-803-2136
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="How Pricing Works">
    <div class="orb-drift-reverse absolute top-[30%] right-[10%] w-[400px] h-[400px] rounded-xl bg-teal/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="reveal">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12]">
              <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
              <span class="text-blue text-xs font-semibold tracking-wide">Simple Process</span>
            </div>
          </div>
        <h2 class="reveal reveal-delay-1 font-display font-800 text-[clamp(1.8rem,4vw,2.8rem)] text-white leading-[1.1] tracking-[-0.02em] mb-6">
          Three steps to <span class="text-gradient">your custom quote</span>
        </h2>
        <p class="reveal reveal-delay-2 text-white/35 text-lg leading-relaxed">
          Simple process. No 12-page proposal. No waiting three weeks to hear back.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="reveal glass-interactive rounded-2xl p-8 relative">
          <div class="absolute top-8 right-8 font-display font-800 text-4xl text-white/[0.04]">01</div>
          <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-white text-lg mb-3">Tell us about your business</h3>
          <p class="text-white/30 text-sm leading-relaxed">Schedule a free call. We'll ask about your goals, your audience, and what's working (or not working) right now.</p>
        </div>

        <!-- Step 2 -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-8 relative">
          <div class="absolute top-8 right-8 font-display font-800 text-4xl text-white/[0.04]">02</div>
          <div class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-white text-lg mb-3">We build your plan</h3>
          <p class="text-white/30 text-sm leading-relaxed">We put together a strategy and quote that matches your goals and budget. Clear scope. Clear pricing. No mystery line items.</p>
        </div>

        <!-- Step 3 -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-8 relative">
          <div class="absolute top-8 right-8 font-display font-800 text-4xl text-white/[0.04]">03</div>
          <div class="w-12 h-12 rounded-xl bg-blue/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
            </svg>
          </div>
          <h3 class="font-display font-700 text-white text-lg mb-3">We get to work</h3>
          <p class="text-white/30 text-sm leading-relaxed">Approve the plan, and we start building. You'll see progress fast. Regular updates, real results, no waiting around.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== SERVICE CATEGORIES ========== -->
  <section class="relative py-28 section-mesh overflow-hidden" aria-label="Service Areas">
    <div class="orb-drift absolute top-[10%] left-[40%] w-[500px] h-[500px] rounded-full bg-blue/[0.04] blur-[140px] pointer-events-none"></div>
    <div class="noise absolute inset-0"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="reveal">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
              <div class="w-1.5 h-1.5 rounded-xl bg-teal animate-pulse"></div>
              <span class="text-teal text-xs font-semibold tracking-wide">Services</span>
            </div>
          </div>
        <h2 class="reveal reveal-delay-1 font-display font-800 text-[clamp(1.8rem,4vw,2.8rem)] text-white leading-[1.1] tracking-[-0.02em] mb-6">
          Services built around <span class="text-gradient">your goals</span>
        </h2>
        <p class="reveal reveal-delay-2 text-white/35 text-lg leading-relaxed">
          Pick one. Pick all five. We'll tailor the scope and price to fit your business.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <div class={`reveal ${i > 0 ? `reveal-delay-${Math.min(i, 5)}` : ''} glass-interactive rounded-2xl p-8 flex flex-col ${i === 4 ? 'md:col-span-2 lg:col-span-1' : ''}`}>
            <div class="flex items-center gap-3 mb-6">
              <div class={`w-12 h-12 rounded-xl ${service.color === 'blue' ? 'bg-blue/10' : 'bg-teal/10'} flex items-center justify-center shrink-0`}>
                {service.icon === 'chart' && (
                  <svg class={`w-6 h-6 ${service.color === 'blue' ? 'text-blue' : 'text-teal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                  </svg>
                )}
                {service.icon === 'palette' && (
                  <svg class={`w-6 h-6 ${service.color === 'blue' ? 'text-blue' : 'text-teal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />
                  </svg>
                )}
                {service.icon === 'code' && (
                  <svg class={`w-6 h-6 ${service.color === 'blue' ? 'text-blue' : 'text-teal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                  </svg>
                )}
                {service.icon === 'mail' && (
                  <svg class={`w-6 h-6 ${service.color === 'blue' ? 'text-blue' : 'text-teal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                )}
                {service.icon === 'spark' && (
                  <svg class={`w-6 h-6 ${service.color === 'blue' ? 'text-blue' : 'text-teal'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                  </svg>
                )}
              </div>
              {service.badge && (
                <span class="px-2.5 py-1 rounded-full text-[10px] font-700 tracking-wider uppercase bg-teal/15 text-teal border border-teal/20">{service.badge}</span>
              )}
            </div>
            <h3 class="font-display font-700 text-white text-lg mb-3">{service.title}</h3>
            <p class="text-white/30 text-sm leading-relaxed mb-8 flex-1">{service.description}</p>
            <a href="/request-demo" class="btn-ghost px-6 py-3 rounded-xl text-white/50 hover:text-white font-medium text-sm text-center">
              Get a Quote
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== WHY CUSTOM PRICING ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Why Custom Pricing">
    <div class="orb-drift absolute bottom-[20%] left-[5%] w-[500px] h-[500px] rounded-full bg-blue/[0.05] blur-[150px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
        <!-- Left: Copy -->
        <div>
          <div class="reveal">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12]">
              <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
              <span class="text-blue text-xs font-semibold tracking-wide">Why Custom</span>
            </div>
          </div>
          <h2 class="reveal reveal-delay-1 font-display font-800 text-[clamp(1.8rem,4vw,2.8rem)] text-white leading-[1.1] tracking-[-0.02em] mb-8">
            Why don't we just <span class="text-gradient">list our prices</span>?
          </h2>
          <div class="reveal reveal-delay-2 space-y-5 text-white/35 text-base lg:text-lg leading-relaxed">
            <p>
              We get it. You want to know the number. Everyone does. But here's the truth: any agency that gives you a price before understanding your business is guessing. And you're paying for that guess.
            </p>
            <p>
              We've seen businesses overpay for bloated packages they didn't need. We've seen others go cheap and get nothing useful. Neither works.
            </p>
            <p>
              Our pricing is based on actual scope, actual hours, and actual deliverables. You'll know exactly what you're paying for and exactly what you're getting. That's not hiding prices. That's respecting your budget.
            </p>
          </div>
        </div>

        <!-- Right: Reasons grid -->
        <div class="space-y-5">
          {reasons.map((reason, i) => (
            <div class={`reveal ${i > 0 ? `reveal-delay-${i}` : ''} glass rounded-xl p-6 flex items-start gap-5`}>
              <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue/10 to-teal/10 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <div>
                <h3 class="font-display font-700 text-white text-base mb-1.5">{reason.title}</h3>
                <p class="text-white/30 text-sm leading-relaxed">{reason.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== FAQ ========== -->
  <section class="relative py-28 section-mesh overflow-hidden" aria-label="Pricing FAQ">
    <div class="noise absolute inset-0"></div>
    <div class="orb-drift-reverse absolute top-[10%] right-[15%] w-[400px] h-[400px] rounded-xl bg-teal/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="reveal">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
              <div class="w-1.5 h-1.5 rounded-xl bg-teal animate-pulse"></div>
              <span class="text-teal text-xs font-semibold tracking-wide">FAQ</span>
            </div>
          </div>
        <h2 class="reveal reveal-delay-1 font-display font-800 text-[clamp(1.8rem,4vw,2.8rem)] text-white leading-[1.1] tracking-[-0.02em]">
          Things people <span class="text-gradient">usually ask</span>
        </h2>
      </div>

      <div class="space-y-4">
        <div class="reveal glass rounded-xl p-6">
          <h3 class="font-display font-700 text-white text-base mb-3">Do you require long-term contracts?</h3>
          <p class="text-white/30 text-sm leading-relaxed">No. We do month-to-month for most services. Some projects (like websites) have a defined scope and timeline. But we never lock you into something you can't walk away from.</p>
        </div>

        <div class="reveal reveal-delay-1 glass rounded-xl p-6">
          <h3 class="font-display font-700 text-white text-base mb-3">What's the typical budget range?</h3>
          <p class="text-white/30 text-sm leading-relaxed">It depends on scope. We work with businesses spending a few hundred a month on email marketing and businesses investing thousands in full-service campaigns. The free consultation is the fastest way to get a real number.</p>
        </div>

        <div class="reveal reveal-delay-2 glass rounded-xl p-6">
          <h3 class="font-display font-700 text-white text-base mb-3">How fast can you start?</h3>
          <p class="text-white/30 text-sm leading-relaxed">Most projects kick off within a week of approval. We move fast because we keep our roster tight. No six-week onboarding process.</p>
        </div>

        <div class="reveal reveal-delay-3 glass rounded-xl p-6">
          <h3 class="font-display font-700 text-white text-base mb-3">Can I bundle multiple services?</h3>
          <p class="text-white/30 text-sm leading-relaxed">Absolutely. Most of our clients use two or more services together. We'll build a package that covers everything and price it as a whole, not a stack of individual line items.</p>
        </div>

        <div class="reveal reveal-delay-4 glass rounded-xl p-6">
          <h3 class="font-display font-700 text-white text-base mb-3">What if I just need a one-time project?</h3>
          <p class="text-white/30 text-sm leading-relaxed">We do those too. Website builds, brand refreshes, email sequence setups. Not everything needs to be ongoing. We'll quote the project and deliver it.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== FINAL CTA ========== -->
  <section class="relative py-28 bg-void overflow-hidden" aria-label="Get Started">
    <div class="orb-drift absolute top-[20%] left-[30%] w-[600px] h-[600px] rounded-full bg-blue/[0.06] blur-[150px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[10%] right-[10%] w-[400px] h-[400px] rounded-xl bg-teal/[0.05] blur-[120px] pointer-events-none"></div>

