---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jerris Heaton - Portfolio" description="Growth & product marketing leader with 8+ years in B2B SaaS. Director of Digital Marketing, agency founder, and builder of systems that drive measurable revenue.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[80vh] flex items-center gradient-mesh noise overflow-hidden">
    <div class="orb-drift absolute top-[10%] right-[5%] w-[600px] h-[600px] rounded-full bg-blue/[0.08] blur-[160px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[5%] left-[0%] w-[500px] h-[500px] rounded-full bg-teal/[0.06] blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 pb-20">
      <div class="max-w-3xl">
        <div class="reveal mb-6">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
            <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
            <span class="text-teal text-xs font-semibold tracking-wide">Available for Opportunities</span>
          </div>
        </div>

        <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.03em] mb-6">
          Jerris <span class="text-gradient">Heaton</span>
        </h1>

        <p class="reveal reveal-delay-2 text-xl sm:text-2xl text-white/50 leading-relaxed mb-4">
          Growth & Product Marketing Leader
        </p>

        <p class="reveal reveal-delay-2 text-base text-white/30 leading-relaxed max-w-xl mb-10">
          8+ years in B2B SaaS. Director of Digital Marketing by day, agency founder by night. I build the GTM programs, email systems, and AI-powered tools that turn marketing departments into revenue engines.
        </p>

        <div class="reveal reveal-delay-3 flex flex-wrap gap-4">
          <a href="#work" class="btn-gradient px-8 py-3.5 rounded-xl text-white font-semibold text-sm inline-block">
            <span>See My Work ↓</span>
          </a>
          <a href="mailto:heaton.jerris@gmail.com" class="glass-interactive px-8 py-3.5 rounded-xl text-white/60 hover:text-white font-medium text-sm inline-block transition-colors">
            heaton.jerris@gmail.com
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== STATS ========== -->
  <section class="relative py-16 bg-void overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="glass-interactive rounded-2xl p-6 text-center">
          <div class="font-display font-800 text-3xl text-gradient mb-1">110%</div>
          <div class="text-white/30 text-xs">Pipeline Growth</div>
        </div>
        <div class="glass-interactive rounded-2xl p-6 text-center">
          <div class="font-display font-800 text-3xl text-white mb-1">29%</div>
          <div class="text-white/30 text-xs">CAC Reduction</div>
        </div>
        <div class="glass-interactive rounded-2xl p-6 text-center">
          <div class="font-display font-800 text-3xl text-gradient mb-1">500+</div>
          <div class="text-white/30 text-xs">Email Campaigns</div>
        </div>
        <div class="glass-interactive rounded-2xl p-6 text-center">
          <div class="font-display font-800 text-3xl text-white mb-1">36k+</div>
          <div class="text-white/30 text-xs">Campaign Clicks</div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== EXPERIENCE ========== -->
  <section id="work" class="relative py-24 bg-void overflow-hidden">
    <div class="orb-drift-reverse absolute top-[20%] right-[-10%] w-[400px] h-[400px] rounded-full bg-blue/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="reveal mb-12">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12] mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
            <span class="text-blue text-xs font-semibold tracking-wide">Experience</span>
          </div>
          <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight">
            Where I've <span class="text-gradient">Built Things</span>
          </h2>
        </div>

        <!-- Squatch Marketing -->
        <div class="reveal glass-interactive rounded-2xl p-8 mb-6">
          <div class="flex items-start justify-between mb-1">
            <h3 class="font-display font-700 text-lg text-white">Founder & Marketing Strategist</h3>
            <span class="text-white/20 text-sm whitespace-nowrap ml-4">2025 - Present</span>
          </div>
          <p class="text-teal text-sm font-medium mb-1">Squatch Marketing - Side Venture</p>
          <p class="text-white/25 text-xs mb-4">A nights-and-weekends project I built to stay sharp on the tools I recommend to my teams.</p>
          <ul class="space-y-2.5 text-white/40 text-sm leading-relaxed">
            <li class="flex gap-3"><span class="text-teal/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Built a full-stack marketing agency from zero,</strong> including brand identity, Astro/Tailwind website on Cloudflare Pages, automated email drip engine (Python + Brevo API), and a prospect-preview-site system that generates branded mockup websites for cold outreach.</span></li>
            <li class="flex gap-3"><span class="text-teal/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Engineered a 12-segment automated drip system</strong> with industry-specific 8-week email sequences, dynamic content swapping, per-contact lifecycle tracking, and a custom analytics dashboard.</span></li>
            <li class="flex gap-3"><span class="text-teal/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Developed a branch-per-prospect preview site pipeline</strong> using Astro + Cloudflare Pages branch deploys, generating personalized branded websites from JSON config files, deployed and live in under 10 minutes per prospect.</span></li>
            <li class="flex gap-3"><span class="text-teal/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Technical stack:</strong> Astro 6, Tailwind CSS 3, Cloudflare Pages/Workers, Brevo transactional API, Python automation, GA4, DKIM/DMARC email authentication, Wrangler CLI.</span></li>
          </ul>
        </div>

        <!-- Medsphere Director -->
        <div class="reveal reveal-delay-1 glass-interactive rounded-2xl p-8 mb-6">
          <div class="flex items-start justify-between mb-1">
            <h3 class="font-display font-700 text-lg text-white">Director of Digital Marketing</h3>
            <span class="text-white/20 text-sm whitespace-nowrap ml-4">May 2021 - Present</span>
          </div>
          <p class="text-blue text-sm font-medium mb-4">Medsphere (CareCloud) - Salt Lake City</p>
          <ul class="space-y-2.5 text-white/40 text-sm leading-relaxed">
            <li class="flex gap-3"><span class="text-blue/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Built and lead a 10+ person marketing organization</strong> across three SaaS product divisions. Set KPIs tied to pipeline and revenue, coached functional leads, and ran quarterly GTM planning with Sales, Product, and Operations.</span></li>
            <li class="flex gap-3"><span class="text-blue/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Scaled sourced pipeline ~110% and reduced CAC ~29%</strong> (demo requests ~400 to ~850; CAC from ~$350 to ~$250) through multi-channel campaign optimization and buyer-intent messaging.</span></li>
            <li class="flex gap-3"><span class="text-blue/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Led lifecycle and content programs</strong> including 500+ email campaigns (~36k clicks), a multi-brand webinar engine (~3/month), and a customer advocacy program producing case studies reused across channels.</span></li>
            <li class="flex gap-3"><span class="text-blue/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Designed and deployed AI workflows</strong> across HTML email creation, sales collateral, and project management, cutting production time 50-70%.</span></li>
            <li class="flex gap-3"><span class="text-blue/60 mt-1.5 shrink-0">-</span><span><strong class="text-white/70">Established a sales enablement program</strong> spanning 100s of slicks, battle cards, competitive analyses, pitch decks, and product walkthrough videos.</span></li>
          </ul>
        </div>

        <!-- ChartLogic -->
        <div class="reveal reveal-delay-2 glass-interactive rounded-2xl p-8 mb-6">
          <div class="flex items-start justify-between mb-1">
            <h3 class="font-display font-700 text-lg text-white">Digital Marketing Specialist</h3>
            <span class="text-white/20 text-sm whitespace-nowrap ml-4">Dec 2018 - May 2021</span>
          </div>
          <p class="text-blue text-sm font-medium mb-4">ChartLogic (Medsphere) - Salt Lake City</p>
          <p class="text-white/40 text-sm leading-relaxed">Executed multi-channel campaigns (email, landing pages, blogs, case studies) and PPC optimizations. Created sales collateral and enablement assets. Improved conversion through segmentation, A/B testing, and data-driven follow-up sequences.</p>
        </div>

        <div class="reveal reveal-delay-3 glass-interactive rounded-2xl p-8">
          <div class="flex items-start justify-between mb-1">
            <h3 class="font-display font-700 text-lg text-white">Marketing Coordinator</h3>
            <span class="text-white/20 text-sm whitespace-nowrap ml-4">May 2016 - Dec 2018</span>
          </div>
          <p class="text-blue text-sm font-medium mb-4">ChartLogic (Medsphere) - Salt Lake City</p>
          <p class="text-white/40 text-sm leading-relaxed">Produced content and managed paid budgets. Partnered with design and sales on enablement assets and campaign execution across digital channels.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== SKILLS ========== -->
  <section class="relative py-24 bg-void overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="reveal mb-12">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12] mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
            <span class="text-teal text-xs font-semibold tracking-wide">Skills</span>
          </div>
          <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight">
            What I <span class="text-gradient">Work With</span>
          </h2>
        </div>

        <div class="reveal grid md:grid-cols-2 gap-6">
          <div class="glass-interactive rounded-2xl p-6">
            <h3 class="font-display font-700 text-sm text-white uppercase tracking-wider mb-4">Strategy & Leadership</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">GTM Strategy & Launches</span>
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">Growth Marketing</span>
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">Product Marketing</span>
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">Demand Generation</span>
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">Cross-Functional Leadership</span>
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">Sales Enablement</span>
              <span class="px-3 py-1.5 rounded-lg bg-blue/[0.08] border border-blue/[0.12] text-blue text-xs font-medium">Buyer Personas & Segmentation</span>
            </div>
          </div>

          <div class="glass-interactive rounded-2xl p-6">
            <h3 class="font-display font-700 text-sm text-white uppercase tracking-wider mb-4">Execution & Channels</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1.5 rounded-lg bg-teal/[0.08] border border-teal/[0.12] text-teal text-xs font-medium">Email Automation & Lifecycle</span>
              <span class="px-3 py-1.5 rounded-lg bg-teal/[0.08] border border-teal/[0.12] text-teal text-xs font-medium">CRO & A/B Testing</span>
              <span class="px-3 py-1.5 rounded-lg bg-teal/[0.08] border border-teal/[0.12] text-teal text-xs font-medium">Webinar Programs</span>
              <span class="px-3 py-1.5 rounded-lg bg-teal/[0.08] border border-teal/[0.12] text-teal text-xs font-medium">Content & SEO</span>
              <span class="px-3 py-1.5 rounded-lg bg-teal/[0.08] border border-teal/[0.12] text-teal text-xs font-medium">PPC / Google Ads</span>
              <span class="px-3 py-1.5 rounded-lg bg-teal/[0.08] border border-teal/[0.12] text-teal text-xs font-medium">Social & Paid Media</span>
            </div>
          </div>

          <div class="glass-interactive rounded-2xl p-6">
            <h3 class="font-display font-700 text-sm text-white uppercase tracking-wider mb-4">Technical & Tools</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Salesforce</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Pardot / HubSpot</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Brevo / Sendinblue</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">GA4 / GTM</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Power BI</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Wrike</span>
            </div>
          </div>

          <div class="glass-interactive rounded-2xl p-6">
            <h3 class="font-display font-700 text-sm text-white uppercase tracking-wider mb-4">Building & Shipping</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Astro / Tailwind CSS</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Cloudflare Pages / Workers</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Python Automation</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">REST APIs / Brevo API</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">Git / GitHub CLI</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">AI Workflows & Prompt Engineering</span>
              <span class="px-3 py-1.5 rounded-lg bg-white/[0.04] border border-white/[0.06] text-white/60 text-xs font-medium">HTML Email (XHTML 1.0)</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ========== EDUCATION ========== -->
  <section class="relative py-16 bg-void overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="reveal glass-interactive rounded-2xl p-8">
          <div class="flex items-start justify-between mb-1">
            <h3 class="font-display font-700 text-lg text-white">B.S. Marketing</h3>
            <span class="text-white/20 text-sm whitespace-nowrap ml-4">2013 - 2017</span>
          </div>
          <p class="text-blue text-sm font-medium">University of Utah</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="relative py-28 section-mesh overflow-hidden">
    <div class="orb-drift absolute top-0 left-[30%] w-[500px] h-[500px] rounded-full bg-teal/[0.05] blur-[140px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal glass-strong rounded-3xl p-10 sm:p-14 lg:p-20 relative overflow-hidden text-center">
        <div class="absolute top-0 left-0 w-1/3 h-1/2 bg-gradient-to-br from-blue/[0.06] to-transparent pointer-events-none rounded-3xl"></div>
        <div class="absolute bottom-0 right-0 w-1/3 h-1/2 bg-gradient-to-tl from-teal/[0.04] to-transparent pointer-events-none rounded-3xl"></div>

        <div class="relative z-10 max-w-xl mx-auto">
          <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight mb-4">
            Let's <span class="text-gradient">talk</span>
          </h2>
          <p class="text-white/35 leading-relaxed mb-10">
            Looking for a marketing leader who builds systems, not slide decks. Available for full-time roles, fractional leadership, or consulting.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="mailto:heaton.jerris@gmail.com" class="btn-gradient px-8 py-3.5 rounded-xl text-white font-semibold text-sm inline-block">
              <span>Email Me</span>
            </a>
            <a href="tel:801-803-2136" class="glass-interactive px-8 py-3.5 rounded-xl text-white/60 hover:text-white font-medium text-sm inline-block transition-colors text-center">
              (801) 803-2136
            </a>
          </div>

          <p class="text-white/15 text-xs mt-8">Utah-based. Open to remote.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
