  .ctable th { font-family:'JetBrains Mono', monospace; font-size:0.66rem; letter-spacing:0.06em; text-transform:uppercase; color:var(--clerri-green); }
  .wave p { font-size:0.92rem; line-height:1.55; margin:0 0 0.5rem; }
  .wave ul { font-size:0.9rem; line-height:1.55; margin:0.25rem 0 0; padding-left:1.2rem; }
  h3 .pill { vertical-align:middle; margin-left:0.4rem; font-size:0.6rem; }
</style>

</ClerriLayout>
