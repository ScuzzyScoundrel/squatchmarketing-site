<script is:inline>
  // Light interactivity for the prototype — toggles only, no real filtering
  document.querySelectorAll('.dir-chip[data-filter]').forEach(chip => {
    chip.addEventListener('click', () => {
      const group = chip.dataset.filter;
      document.querySelectorAll('.dir-chip[data-filter="' + group + '"]').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });
  function dmRange(v) {
    document.getElementById('dm-range-val').textContent = v + ' mi';
  }
  function dmFilter() {
    // visual feedback only — would query backend in real build
    const btn = document.querySelector('.dir-search-btn');
    const orig = btn.textContent;
    btn.textContent = 'Searching…';
    setTimeout(() => { btn.textContent = orig; }, 800);
  }
</script>

