---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    title: "Why Most Marketing Dashboards Lie to You",
    excerpt: "Vanity metrics feel good but hide the truth. Here's how to build reporting that actually tracks revenue impact.",
    date: "March 20, 2026",
    readTime: "6 min read",
    category: "Strategy",
    gradient: "from-blue/30 via-blue/10 to-teal/20",
    categoryColor: "text-blue bg-blue/10 border-blue/20",
    slug: "#",
  },
  {
    title: "The Email Sequence That Converts Cold Leads",
    excerpt: "A 5-email framework we've used across 30+ campaigns. No gimmicks, just structure that moves people to act.",
    date: "March 12, 2026",
    readTime: "8 min read",
    category: "Email",
    gradient: "from-teal/30 via-teal/10 to-blue/20",
    categoryColor: "text-teal bg-teal/10 border-teal/20",
    slug: "#",
  },
  {
    title: "AI in Marketing: What Actually Works Right Now",
    excerpt: "We tested 12 AI tools across real client campaigns. Some saved hours. Most were noise. Here's the honest breakdown.",
    date: "March 4, 2026",
    readTime: "10 min read",
    category: "AI",
    gradient: "from-blue/20 via-teal/15 to-blue/30",
    categoryColor: "text-blue-light bg-blue/10 border-blue/20",
    slug: "#",
  },
  {
    title: "Landing Pages That Convert Above 8%",
    excerpt: "Forget best practices lists. We're sharing the exact layout patterns and copy structures behind our highest-performing pages.",
    date: "February 25, 2026",
    readTime: "7 min read",
    category: "Web Dev",
    gradient: "from-teal/20 via-blue/15 to-teal/30",
    categoryColor: "text-teal-light bg-teal/10 border-teal/20",
    slug: "#",
  },
];
---

<Layout title="Blog" description="Marketing insights, strategies, and real-world case studies from Squatch Marketing. Practical advice on digital marketing, email campaigns, web development, and AI workflows.">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-[60vh] flex items-center gradient-mesh noise overflow-hidden">
    <!-- Floating orbs -->
    <div class="orb-drift absolute top-[15%] left-[5%] w-[500px] h-[500px] rounded-full bg-blue/[0.08] blur-[140px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[10%] right-[0%] w-[450px] h-[450px] rounded-full bg-teal/[0.06] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 pb-20">
      <div class="max-w-3xl">
        <!-- Eyebrow -->
        <div class="reveal flex items-center gap-3 mb-8">
          <div class="h-px w-12 bg-gradient-to-r from-blue to-teal"></div>
          <span class="text-teal text-sm font-medium tracking-widest uppercase">Our Blog</span>
        </div>

        <!-- Headline -->
        <h1 class="reveal reveal-delay-1 font-display font-800 text-5xl sm:text-6xl lg:text-7xl text-white leading-[1.1] tracking-tight mb-8">
          Insights <span class="text-gradient">&amp; Ideas</span>
        </h1>

        <!-- Subtitle -->
        <p class="reveal reveal-delay-2 text-lg sm:text-xl text-white/40 leading-relaxed max-w-xl">
          Practical marketing advice from the trenches. No fluff, no filler. Just the strategies and tools we actually use with our clients.
        </p>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- ========== POSTS GRID ========== -->
  <section class="relative py-24 bg-void overflow-hidden" aria-label="Blog posts">
    <div class="orb-drift-reverse absolute top-[30%] right-[-10%] w-[400px] h-[400px] rounded-full bg-blue/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map((post, i) => (
          <a
            href={post.slug}
            class={`reveal ${i > 0 ? `reveal-delay-${i}` : ''} group glass-interactive rounded-2xl overflow-hidden flex flex-col`}
          >
            {/* Gradient placeholder image */}
            <div class={`h-52 bg-gradient-to-br ${post.gradient} relative overflow-hidden`}>
              {/* Noise overlay on image area */}
              <div class="absolute inset-0 opacity-40" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E&quot;); background-repeat: repeat;"></div>
              {/* Decorative grid lines */}
              <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>
              {/* Category tag */}
              <div class="absolute top-4 left-4">
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium border ${post.categoryColor}`}>
                  {post.category}
                </span>
              </div>
            </div>

            {/* Content */}
            <div class="p-7 flex flex-col flex-1">
              {/* Meta */}
              <div class="flex items-center gap-3 text-xs text-white/30 mb-4">
                <time>{post.date}</time>
                <span class="w-1 h-1 rounded-full bg-white/20"></span>
                <span>{post.readTime}</span>
              </div>

              <h2 class="font-display font-700 text-xl text-white mb-3 group-hover:text-blue-light transition-colors duration-300 leading-snug">
                {post.title}
              </h2>

              <p class="text-white/35 text-sm leading-relaxed flex-1">
                {post.excerpt}
              </p>

              {/* Read more */}
              <div class="flex items-center gap-2 mt-6 text-sm text-blue font-medium group-hover:text-teal transition-colors duration-300">
                <span>Read more</span>
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== SECTION DIVIDER ========== -->
  <div class="section-divider"></div>

  <!-- ========== NEWSLETTER / CTA ========== -->
  <section class="relative py-28 section-mesh overflow-hidden" aria-label="Newsletter signup">
    <div class="orb-drift absolute top-0 left-[30%] w-[500px] h-[500px] rounded-full bg-teal/[0.05] blur-[140px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal glass-strong rounded-3xl p-10 sm:p-14 lg:p-20 relative overflow-hidden text-center">
        <!-- Inner gradient accents -->
        <div class="absolute top-0 left-0 w-1/3 h-1/2 bg-gradient-to-br from-blue/[0.06] to-transparent pointer-events-none rounded-3xl"></div>
        <div class="absolute bottom-0 right-0 w-1/3 h-1/2 bg-gradient-to-tl from-teal/[0.04] to-transparent pointer-events-none rounded-3xl"></div>

        <div class="relative z-10 max-w-xl mx-auto">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue/15 to-teal/15 border border-white/[0.06] flex items-center justify-center mx-auto mb-8">
            <svg class="w-7 h-7 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>

          <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight mb-4">
            More posts <span class="text-gradient">coming soon</span>
          </h2>
          <p class="text-white/35 leading-relaxed mb-10">
            We're just getting started. Drop your email and we'll send you new posts the moment they go live. One email per post. Unsubscribe anytime.
          </p>

          <form action="#" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
            <input
              type="email"
              name="newsletter-email"
              required
              class="flex-1 px-5 py-3.5 bg-white/[0.03] border border-white/[0.06] rounded-xl text-white placeholder:text-white/20 text-sm focus:outline-none focus:border-blue/40 focus:bg-white/[0.05] transition-all duration-300"
              placeholder="you@company.com"
            />
            <button type="submit" class="btn-gradient px-7 py-3.5 rounded-xl text-white font-semibold text-sm whitespace-nowrap">
              <span>Subscribe</span>
            </button>
          </form>

          <p class="text-white/15 text-xs mt-4">No spam. No third parties. Just good marketing content.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
