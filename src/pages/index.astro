---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- ========== HERO ========== -->
  <section class="relative min-h-screen flex items-center gradient-mesh noise topo overflow-hidden" aria-label="Hero">
    <div class="orb-drift absolute top-[10%] left-[3%] w-[700px] h-[700px] rounded-full bg-blue/[0.08] blur-[160px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[5%] right-[-5%] w-[600px] h-[600px] rounded-full bg-teal/[0.06] blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 lg:pt-44 pb-32">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">
        <!-- Left content -->
        <div>
          <h1 class="reveal font-display font-800 text-[clamp(2.8rem,6.5vw,5.5rem)] text-white leading-[1.1] tracking-[-0.03em] mb-7">
            Marketing that<br />
            <span class="text-gradient">moves the needle.</span>
          </h1>

          <p class="reveal reveal-delay-1 text-lg lg:text-xl text-white/35 leading-relaxed max-w-lg mb-10">
            Strategy, creative, and AI-powered workflows — built around your business, not a template.
          </p>

          <div class="reveal reveal-delay-2 flex flex-wrap gap-3">
            <a href="/request-demo" class="btn-gradient px-8 py-4 rounded-xl text-white font-semibold text-[15px]">
              <span>Get Started</span>
            </a>
            <a href="/solutions" class="btn-ghost px-8 py-4 rounded-xl text-white/50 hover:text-white font-medium text-[15px]">
              Explore Solutions
            </a>
          </div>
        </div>

        <!-- Right — dashboard mockup (scaled up) -->
        <div class="hidden lg:block relative">
          <div class="glass-strong rounded-2xl p-1.5 glow relative">
            <div class="bg-abyss/90 rounded-xl overflow-hidden">
              <!-- Title bar -->
              <div class="flex items-center gap-2 px-6 py-3.5 border-b border-white/[0.05]">
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <div class="w-3 h-3 rounded-full bg-white/10"></div>
                <svg class="w-3 h-3 text-white/10" viewBox="0 0 24 28" fill="currentColor"><ellipse cx="12" cy="18" rx="7" ry="9.5"/><circle cx="6" cy="5.5" r="2.2"/><circle cx="10" cy="3" r="2"/><circle cx="14.5" cy="3" r="2"/><circle cx="18.5" cy="5.5" r="2.2"/><circle cx="4" cy="9" r="1.8"/></svg>
                <span class="ml-4 text-xs text-white/30 font-medium">Campaign Dashboard</span>
              </div>
              <!-- Dashboard content -->
              <div id="dashboard" class="p-6 space-y-5">
                <!-- Metric row — animated counters -->
                <div class="grid grid-cols-3 gap-4">
                  <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04] metric-alive">
                    <div class="text-xs text-white/40 mb-2 font-medium">Revenue</div>
                    <div class="text-3xl font-display font-800 text-white leading-none" data-count="42.8" data-prefix="$" data-suffix="k">$0k</div>
                    <div class="text-xs text-teal mt-2 font-medium">+18.3%</div>
                  </div>
                  <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04] metric-alive">
                    <div class="text-xs text-white/40 mb-2 font-medium">Conversions</div>
                    <div class="text-3xl font-display font-800 text-white leading-none" data-count="1247" data-prefix="" data-suffix="">0</div>
                    <div class="text-xs text-teal mt-2 font-medium">+24.1%</div>
                  </div>
                  <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04] metric-alive">
                    <div class="text-xs text-white/40 mb-2 font-medium">ROAS</div>
                    <div class="text-3xl font-display font-800 text-gradient leading-none" data-count="4.2" data-prefix="" data-suffix="x">0x</div>
                    <div class="text-xs text-teal mt-2 font-medium">+0.8x</div>
                  </div>
                </div>
                <!-- Chart bars — animated -->
                <div class="bg-white/[0.03] rounded-xl p-5 border border-white/[0.04]">
                  <div class="flex items-center justify-between mb-4">
                    <span class="text-xs text-white/40 font-medium">Weekly Performance</span>
                    <span class="text-xs text-teal font-medium">+32% avg</span>
                  </div>
                  <div class="flex items-end gap-2 h-24 bar-alive" id="chart-bars">
                    <div class="chart-bar flex-1 bg-gradient-to-t from-blue to-blue/40 rounded" data-height="45"></div>
                    <div class="chart-bar flex-1 bg-gradient-to-t from-blue to-blue/40 rounded" data-height="62"></div>
                    <div class="chart-bar flex-1 bg-gradient-to-t from-blue to-blue/50 rounded" data-height="38"></div>
                    <div class="chart-bar flex-1 bg-gradient-to-t from-blue to-teal/60 rounded" data-height="85"></div>
                    <div class="chart-bar flex-1 bg-gradient-to-t from-teal/90 to-teal/50 rounded" data-height="72"></div>
                    <div class="chart-bar flex-1 bg-gradient-to-t from-teal to-teal/50 rounded" data-height="93"></div>
                    <div class="chart-bar flex-1 bg-gradient-to-t from-teal to-teal/60 rounded" data-height="100"></div>
                  </div>
                  <div class="flex justify-between mt-3 text-[10px] text-white/25">
                    <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating notification — overlapping -->
          <div class="absolute -bottom-8 -left-10 glass-strong rounded-xl p-5 w-56 glow z-10">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-teal/15 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <div>
                <div class="text-sm text-white font-semibold flex items-center gap-2">Campaign Live <div class="w-2 h-2 rounded-full bg-teal animate-pulse-dot"></div></div>
                <div class="text-xs text-white/35">Q1 Email Sequence</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Twin peaks with valley glow — pure CSS, no SVG blur -->
    <div class="absolute bottom-0 left-0 right-0 z-[2] pointer-events-none" style="height:55%">
      <!-- Valley glow — bright, visible, rising from the gap -->
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[50%] h-[90%]" style="background:radial-gradient(ellipse 100% 80% at 50% 100%, rgba(46,163,242,0.15) 0%, rgba(38,209,189,0.08) 30%, transparent 70%)"></div>
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[25%] h-[70%]" style="background:radial-gradient(ellipse 100% 70% at 50% 100%, rgba(38,209,189,0.12) 0%, rgba(46,163,242,0.05) 40%, transparent 70%)"></div>

      <!-- Left peak — massive triangle via clip-path -->
      <div class="absolute bottom-0 left-0 w-[55%] h-full" style="background:linear-gradient(to bottom, #0A1E30 0%, #000A12 80%);clip-path:polygon(0% 100%, 0% 45%, 15% 35%, 30% 25%, 45% 10%, 60% 5%, 78% 18%, 88% 40%, 100% 55%, 100% 100%);opacity:0.6"></div>

      <!-- Right peak — massive triangle via clip-path -->
      <div class="absolute bottom-0 right-0 w-[55%] h-full" style="background:linear-gradient(to bottom, #0A1E30 0%, #000A12 80%);clip-path:polygon(0% 55%, 12% 40%, 22% 18%, 40% 5%, 55% 10%, 70% 25%, 85% 35%, 100% 45%, 100% 100%, 0% 100%);opacity:0.6"></div>

      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-void to-transparent"></div>
    </div>
  </section>

  <!-- ========== AI WORKFLOWS — FEATURED ========== -->
  <section class="relative pt-4 pb-28 bg-void overflow-visible" aria-label="AI Workflows">
    <div class="orb-drift absolute top-0 left-[40%] w-[500px] h-[500px] rounded-full bg-teal/[0.04] blur-[140px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal relative">
        <div class="glass-strong rounded-3xl overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-br from-blue/[0.04] via-transparent to-teal/[0.04] pointer-events-none"></div>
          <div class="noise absolute inset-0 rounded-3xl"></div>

          <div class="relative z-10 grid lg:grid-cols-[1fr_1.1fr] gap-8 lg:gap-0">
            <!-- Left — content -->
            <div class="p-10 lg:p-14 flex flex-col justify-center">
              <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-teal/[0.08] border border-teal/[0.12] w-fit mb-6">
                <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
                <span class="text-teal text-xs font-semibold tracking-wide">New Service</span>
              </div>
              <h2 class="font-display font-800 text-3xl lg:text-4xl text-white leading-tight mb-5">
                Marketing AI<br /><span class="text-gradient">Workflows</span>
              </h2>
              <p class="text-ink-bright text-base leading-relaxed mb-6 max-w-md">
                AI isn't replacing marketers — it's making them 10x faster. We build custom Claude-powered workflows for content creation, email campaigns, social copy, and market research.
              </p>
              <ul class="space-y-3 mb-8">
                <li class="flex items-center gap-3 text-[15px] text-white/80">
                  <div class="w-6 h-6 rounded-md bg-teal/15 flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  </div>
                  AI-powered content pipelines
                </li>
                <li class="flex items-center gap-3 text-[15px] text-white/80">
                  <div class="w-6 h-6 rounded-md bg-teal/15 flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  </div>
                  Automated email sequence generation
                </li>
                <li class="flex items-center gap-3 text-[15px] text-white/80">
                  <div class="w-6 h-6 rounded-md bg-teal/15 flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                  </div>
                  Consulting &amp; setup for your team
                </li>
              </ul>
              <a href="/solutions/ai-workflows" class="btn-gradient px-7 py-3.5 rounded-xl text-white font-semibold text-sm w-fit">
                <span>Learn More</span>
              </a>
            </div>

            <!-- Right — AI workflow diagram (bigger, higher contrast) -->
            <div class="hidden lg:flex items-center justify-center p-8 lg:p-12 relative">
              <div class="w-full max-w-md space-y-4">
                <!-- Step 1 -->
                <div class="bg-white/[0.04] rounded-2xl p-5 border border-white/[0.08] border-l-[3px] border-l-blue/60">
                  <div class="flex items-center gap-4 mb-3">
                    <div class="w-8 h-8 rounded-lg bg-blue/20 flex items-center justify-center">
                      <span class="text-blue text-sm font-800 font-display">1</span>
                    </div>
                    <span class="text-white text-sm font-bold">Brief Ingestion</span>
                    <span class="ml-auto text-[10px] text-teal bg-teal/15 px-2.5 py-1 rounded-full font-semibold">auto</span>
                  </div>
                  <p class="text-white/50 text-sm leading-relaxed pl-12">Parse campaign brief, extract audience segments and key messaging</p>
                </div>

                <!-- Connection -->
                <div class="flex justify-center"><div class="w-0.5 h-5 bg-gradient-to-b from-blue/30 to-teal/30 rounded-full animate-pulse-glow"></div></div>

                <!-- Step 2 -->
                <div class="bg-white/[0.04] rounded-2xl p-5 border border-white/[0.08] border-l-[3px] border-l-teal/60">
                  <div class="flex items-center gap-4 mb-3">
                    <div class="w-8 h-8 rounded-lg bg-teal/20 flex items-center justify-center">
                      <span class="text-teal text-sm font-800 font-display">2</span>
                    </div>
                    <span class="text-white text-sm font-bold">Content Generation</span>
                    <span class="ml-auto text-[10px] text-teal bg-teal/15 px-2.5 py-1 rounded-full font-semibold">AI</span>
                  </div>
                  <p class="text-white/50 text-sm leading-relaxed pl-12">Generate email sequences, social copy, and landing page content in minutes</p>
                </div>

                <!-- Connection -->
                <div class="flex justify-center"><div class="w-0.5 h-5 bg-gradient-to-b from-teal/30 to-blue/30 rounded-full animate-pulse-glow anim-delay-2"></div></div>

                <!-- Step 3 -->
                <div class="bg-white/[0.04] rounded-2xl p-5 border border-white/[0.08] border-l-[3px] border-l-blue/60">
                  <div class="flex items-center gap-4 mb-3">
                    <div class="w-8 h-8 rounded-lg bg-blue/20 flex items-center justify-center">
                      <span class="text-blue text-sm font-800 font-display">3</span>
                    </div>
                    <span class="text-white text-sm font-bold">Review & Deploy</span>
                    <span class="ml-auto text-[10px] text-white/50 bg-white/[0.06] px-2.5 py-1 rounded-full font-semibold">you</span>
                  </div>
                  <p class="text-white/50 text-sm leading-relaxed pl-12">Review AI drafts, approve with one click, auto-schedule deployment</p>
                </div>

                <!-- Output summary -->
                <div class="glass-strong rounded-xl p-4 glow mt-5">
                  <div class="flex items-center gap-3 mb-3">
                    <div class="w-5 h-5 rounded-md bg-gradient-to-br from-blue to-teal"></div>
                    <span class="text-sm text-white/60 font-semibold">Output</span>
                  </div>
                  <div class="flex items-center gap-4">
                    <span class="text-sm text-teal font-semibold">3 emails</span>
                    <span class="text-white/15">|</span>
                    <span class="text-sm text-blue font-semibold">12 social posts</span>
                    <span class="text-white/15">|</span>
                    <span class="text-sm text-white/40 font-medium">1 landing page</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== RESULTS STRIP ========== -->
  <section class="relative py-16 bg-void overflow-hidden" aria-label="Results">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal glass-strong rounded-2xl p-8 lg:p-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4 text-center">
          <div>
            <div class="text-3xl lg:text-4xl font-display font-800 text-gradient mb-2" data-count="38" data-prefix="" data-suffix="%" id="stat-1">0%</div>
            <div class="text-sm text-white/35">Avg. email open rate</div>
            <div class="text-xs text-white/15 mt-1">Industry avg: 21%</div>
          </div>
          <div>
            <div class="text-3xl lg:text-4xl font-display font-800 text-white mb-2" data-count="4.2" data-prefix="" data-suffix="x" id="stat-2">0x</div>
            <div class="text-sm text-white/35">Return on ad spend</div>
            <div class="text-xs text-white/15 mt-1">Industry avg: 2.8x</div>
          </div>
          <div>
            <div class="text-3xl lg:text-4xl font-display font-800 text-gradient mb-2" data-count="10" data-prefix="" data-suffix="x" id="stat-3">0x</div>
            <div class="text-sm text-white/35">Faster with AI workflows</div>
            <div class="text-xs text-white/15 mt-1">vs. manual content creation</div>
          </div>
          <div>
            <div class="text-3xl lg:text-4xl font-display font-800 text-white mb-2" data-count="100" data-prefix="" data-suffix="" id="stat-4">0</div>
            <div class="text-sm text-white/35">Lighthouse performance</div>
            <div class="text-xs text-white/15 mt-1">This site. Right now.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES — BENTO GRID (5 cards) ========== -->
  <section class="relative pt-8 pb-28 bg-void overflow-hidden" aria-label="Services">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="reveal max-w-xl mb-14">
        <h2 class="font-display font-800 text-3xl lg:text-[2.75rem] text-white leading-tight mb-4">
          Five capabilities,<br /><span class="text-gradient">one team.</span>
        </h2>
        <p class="text-ink text-lg leading-relaxed">
          Strategy, design, development, AI, and delivery — all under one roof.
        </p>
      </div>

      <!-- Bento grid — 5 cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Digital Marketing — wide with mini chart -->
        <a href="/solutions/digital-marketing" class="reveal lg:col-span-2 group glass-interactive rounded-2xl p-10 lg:p-12 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-blue/[0.04] to-transparent pointer-events-none"></div>
          <div class="relative grid lg:grid-cols-[1fr_auto] gap-8 items-start">
            <div>
              <div class="w-14 h-14 rounded-xl bg-blue/10 flex items-center justify-center mb-6 group-hover:bg-blue/20 transition-colors duration-500">
                <svg class="w-7 h-7 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
                </svg>
              </div>
              <h3 class="font-display font-700 text-2xl text-white mb-3 group-hover:text-blue transition-colors duration-300">Digital Marketing</h3>
              <p class="text-ink text-[15px] leading-relaxed max-w-md mb-7">Paid social campaigns, retargeting, and data-driven growth strategies across every major platform.</p>
              <div class="flex flex-wrap gap-2">
                <span class="text-xs px-3.5 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Facebook</span>
                <span class="text-xs px-3.5 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Instagram</span>
                <span class="text-xs px-3.5 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">LinkedIn</span>
                <span class="text-xs px-3.5 py-1.5 rounded-full bg-white/[0.04] text-white/40 border border-white/[0.06]">Retargeting</span>
              </div>
            </div>
            <!-- Mini sparkline -->
            <div class="hidden lg:block w-40">
              <div class="text-xs text-white/30 mb-2 font-medium">Avg. ROAS Trend</div>
              <div class="flex items-end gap-1 h-16 bar-alive">
                <div class="flex-1 bg-blue/20 rounded" style="height:30%"></div>
                <div class="flex-1 bg-blue/25 rounded" style="height:45%"></div>
                <div class="flex-1 bg-blue/25 rounded" style="height:40%"></div>
                <div class="flex-1 bg-blue/30 rounded" style="height:60%"></div>
                <div class="flex-1 bg-blue/35 rounded" style="height:55%"></div>
                <div class="flex-1 bg-teal/35 rounded" style="height:75%"></div>
                <div class="flex-1 bg-teal/40 rounded" style="height:70%"></div>
                <div class="flex-1 bg-teal/45 rounded" style="height:85%"></div>
                <div class="flex-1 bg-teal/50 rounded" style="height:100%"></div>
              </div>
            </div>
          </div>
          <svg class="absolute top-10 right-10 w-6 h-6 text-white/[0.06] group-hover:text-blue/50 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
          </svg>
        </a>

        <!-- Email Marketing — tall with template mockup -->
        <a href="/solutions/email-marketing" class="reveal reveal-delay-1 lg:row-span-2 group glass-interactive rounded-2xl p-9 relative overflow-hidden flex flex-col">
          <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-teal/[0.04] to-transparent pointer-events-none"></div>
          <div class="relative flex-1 flex flex-col">
            <div class="w-14 h-14 rounded-xl bg-teal/10 flex items-center justify-center mb-6 group-hover:bg-teal/20 transition-colors duration-500">
              <svg class="w-7 h-7 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3 class="font-display font-700 text-2xl text-white mb-3 group-hover:text-teal transition-colors duration-300">Email Marketing</h3>
            <p class="text-ink text-[15px] leading-relaxed mb-8">End-to-end campaign management. ESP setup, branded templates, list hygiene, automation, and optimization.</p>

            <!-- Email template mockup — bigger -->
            <div class="mt-auto bg-white/[0.03] rounded-2xl p-5 border border-white/[0.06]">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue to-teal"></div>
                <div class="flex-1">
                  <div class="h-2.5 w-28 rounded bg-white/[0.08]"></div>
                  <div class="h-2 w-20 rounded bg-white/[0.04] mt-1.5"></div>
                </div>
              </div>
              <div class="h-20 rounded-xl bg-gradient-to-br from-blue/[0.08] to-teal/[0.05] mb-4 flex items-center justify-center border border-white/[0.04]">
                <span class="text-xs text-white/25 font-medium">Hero Image</span>
              </div>
              <div class="space-y-2 mb-4">
                <div class="h-2.5 w-full rounded bg-white/[0.06]"></div>
                <div class="h-2.5 w-5/6 rounded bg-white/[0.05]"></div>
                <div class="h-2.5 w-2/3 rounded bg-white/[0.04]"></div>
              </div>
