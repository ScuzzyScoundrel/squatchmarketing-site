---

<Layout title="Our Work" description="Real preview sites and email designs we've built for small businesses. 12+ custom websites and hand-coded email campaigns — see the quality before you buy.">

  <!-- HERO -->
  <section class="relative min-h-[60vh] flex items-center gradient-mesh noise overflow-hidden">
    <div class="orb-drift absolute top-[15%] left-[5%] w-[500px] h-[500px] rounded-full bg-blue/[0.08] blur-[140px] pointer-events-none"></div>
    <div class="orb-drift-reverse absolute bottom-[10%] right-[0%] w-[450px] h-[450px] rounded-full bg-teal/[0.06] blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-36 pb-20">
      <div class="max-w-3xl">
        <div class="reveal mb-6">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12]">
            <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
            <span class="text-teal text-xs font-semibold tracking-wide">Our Work</span>
          </div>
        </div>

        <h1 class="reveal reveal-delay-1 font-display font-800 text-[clamp(2.5rem,5.5vw,4.5rem)] text-white leading-[1.1] tracking-[-0.03em] mb-8">
          Real websites. <span class="text-gradient">Real emails.</span>
        </h1>

        <p class="reveal reveal-delay-2 text-lg sm:text-xl text-white/40 leading-relaxed max-w-xl">
          Live preview sites and hand-coded email designs we've built for small businesses. Scroll down to see the work. Yours could look like this next week.
        </p>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-void to-transparent pointer-events-none z-10"></div>
  </section>

  <!-- SITES GRID -->
  <section class="relative py-24 bg-void overflow-hidden" aria-label="Preview sites">
    <div class="orb-drift-reverse absolute top-[30%] right-[-10%] w-[400px] h-[400px] rounded-full bg-blue/[0.04] blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal mb-12 text-center">
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-blue/[0.08] border border-blue/[0.12] mb-5">
          <div class="w-1.5 h-1.5 rounded-full bg-blue animate-pulse"></div>
          <span class="text-blue text-xs font-semibold tracking-wide">Websites</span>
        </div>
        <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight">
          12 live preview sites.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sites.map((site, i) => (
          <a
            href={site.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`reveal ${i > 0 && i < 6 ? `reveal-delay-${i}` : ''} group glass-interactive rounded-2xl overflow-hidden flex flex-col`}
          >
            <div class={`h-52 bg-gradient-to-br ${site.gradient} relative overflow-hidden`}>
              <div class="absolute inset-0 opacity-40" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E&quot;); background-repeat: repeat;"></div>
              <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>
              <div class="absolute top-4 left-4">
                <span class={`inline-block px-3 py-1 rounded-xl text-xs font-medium border ${site.categoryColor}`}>
                  {site.industry}
                </span>
              </div>
              <div class="absolute bottom-4 right-4">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-medium bg-white/10 backdrop-blur-sm text-white/80 border border-white/10">
                  <div class="w-1.5 h-1.5 rounded-full bg-green-400"></div>
                  Live
                </span>
              </div>
            </div>

            <div class="p-6 flex flex-col flex-1">
              <h2 class="font-display font-700 text-lg text-white mb-1 group-hover:text-blue-light transition-colors duration-300 leading-snug">
                {site.name}
              </h2>
              <p class="text-white/30 text-sm mb-5">{site.location}</p>

              <div class="flex items-center gap-2 mt-auto text-sm text-blue font-medium group-hover:text-teal transition-colors duration-300">
                <span>View Site</span>
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- EMAIL CAMPAIGNS -->
  <section class="relative py-24 bg-void overflow-hidden" aria-label="Email campaigns">
    <div class="orb-drift absolute top-[10%] left-[-5%] w-[450px] h-[450px] rounded-full bg-teal/[0.05] blur-[140px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="reveal mb-16 text-center">
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-xl bg-teal/[0.08] border border-teal/[0.12] mb-5">
          <div class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></div>
          <span class="text-teal text-xs font-semibold tracking-wide">Email Campaigns</span>
        </div>
        <h2 class="font-display font-800 text-3xl sm:text-4xl text-white leading-tight mb-4">
          Hand-coded emails <span class="text-gradient">for every industry.</span>
        </h2>
        <p class="text-white/40 text-base leading-relaxed max-w-xl mx-auto">
          No Mailchimp templates. No AI slop. Every email below is custom HTML, designed to match the brand and the moment. Scroll through a few examples.
        </p>
      </div>

      <div class="flex flex-col gap-12 items-center">

        <!-- EMAIL MOCKUP 1: Chiropractic Recall -->
        <div class="reveal w-full max-w-[680px]">
          <div class="flex items-center justify-between mb-3 px-1">
            <span class="text-white/30 text-xs font-medium tracking-wide uppercase">Chiropractic · Appointment Recall</span>
            <span class="inline-flex items-center gap-1.5 text-[11px] text-white/40">
              <div class="w-1.5 h-1.5 rounded-full bg-green-400"></div>
              Transactional
            </span>
          </div>

          <div class="glass-interactive rounded-2xl overflow-hidden">
            <!-- Inbox Chrome -->
            <div class="flex items-start gap-3 p-4 border-b border-white/5 bg-white/[0.02]">
              <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center font-semibold text-white text-sm" style="background:linear-gradient(135deg, #10B981 0%, #059669 100%);">FF</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-white text-sm font-semibold">FormFit Chiropractic</span>
                  <span class="text-white/30 text-xs">&lt;hello@formfitchiro.com&gt;</span>
                </div>
                <div class="text-white/80 text-sm mt-0.5 font-medium">Hey Sarah, time for a check-in?</div>
                <div class="text-white/30 text-xs mt-0.5">Your spine called. Let's take a look.</div>
              </div>
              <span class="text-white/30 text-xs flex-shrink-0">9:42 AM</span>
            </div>

            <!-- Email Body (light theme, cream background) -->
            <div style="background:#FAFAF7; padding:0;">
              <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px; margin:0 auto;">
                <tr><td align="center" style="padding:32px 24px 8px 24px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">
                  <div style="font-family:'Syne', Helvetica, Arial, sans-serif; font-weight:700; font-size:20px; color:#064E3B; letter-spacing:-0.02em;">FormFit<span style="color:#10B981;">.</span></div>
                </td></tr>

                <tr><td style="padding:24px 32px 8px 32px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">
                  <div style="display:inline-block; padding:5px 12px; border-radius:50px; background:#ECFDF5; border:1px solid #D1FAE5; font-size:11px; font-weight:600; color:#059669; letter-spacing:0.4px; margin-bottom:16px;">● FRIENDLY REMINDER</div>
                  <h1 style="margin:0 0 14px 0; font-family:'Syne', Helvetica, Arial, sans-serif; font-size:30px; line-height:1.2; color:#111827; font-weight:700; letter-spacing:-0.02em;">
                    Hey Sarah,<br>time for an adjustment?
                  </h1>
                  <p style="margin:0 0 24px 0; font-size:15px; line-height:1.65; color:#4B5563;">
                    It's been about six weeks since your last visit. We noticed your usual check-in window is coming up, so just a quick nudge. No pressure, but if you've been feeling any of the old tightness creeping back, now's a good time to book in.
                  </p>
                </td></tr>

                <tr><td style="padding:0 32px 24px 32px;">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background:#F0FDF4; border:1px solid #D1FAE5; border-radius:14px;">
                    <tr><td style="padding:18px 20px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">
                      <div style="font-size:11px; font-weight:600; color:#059669; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:6px;">Your Last Visit</div>
                      <div style="font-size:15px; color:#064E3B; font-weight:600;">March 6, 2026 · Lower back adjustment</div>
                      <div style="font-size:13px; color:#4B5563; margin-top:4px;">Dr. Chen's recommended interval: 4–6 weeks between adjustments.</div>
                    </td></tr>
                  </table>
                </td></tr>

                <tr><td align="center" style="padding:0 32px 32px 32px;">
                  <table border="0" cellpadding="0" cellspacing="0">
                    <tr><td bgcolor="#10B981" style="background-color:#10B981; border-radius:10px;">
                      <a href="#" style="display:block; padding:14px 36px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:15px; font-weight:600; color:#FFFFFF; text-decoration:none; background:linear-gradient(135deg, #10B981 0%, #059669 100%); border-radius:10px;">Book My Adjustment →</a>
                    </td></tr>
                  </table>
                  <div style="font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:13px; color:#6B7280; margin-top:16px;">Or just reply to this email and we'll find a time.</div>
                </td></tr>

                <tr><td align="center" style="padding:24px 32px 32px 32px; border-top:1px solid #E5E7EB; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:11px; color:#9CA3AF; line-height:1.6;">
                  FormFit Chiropractic · 1425 N State Street, Pleasant Grove UT<br>
                  <a href="#" style="color:#10B981; text-decoration:none;">Reschedule</a> · <a href="#" style="color:#9CA3AF; text-decoration:none;">Unsubscribe</a>
                </td></tr>
              </table>
            </div>
          </div>
        </div>

        <!-- EMAIL MOCKUP 2: Restaurant Flash Event -->
        <div class="reveal w-full max-w-[680px]">
          <div class="flex items-center justify-between mb-3 px-1">
            <span class="text-white/30 text-xs font-medium tracking-wide uppercase">Restaurant · Flash Event</span>
            <span class="inline-flex items-center gap-1.5 text-[11px] text-white/40">
              <div class="w-1.5 h-1.5 rounded-full bg-amber-400"></div>
              Broadcast
            </span>
          </div>

          <div class="glass-interactive rounded-2xl overflow-hidden">
            <!-- Inbox Chrome -->
            <div class="flex items-start gap-3 p-4 border-b border-white/5 bg-white/[0.02]">
              <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center font-semibold text-white text-sm" style="background:linear-gradient(135deg, #D97706 0%, #7F1D1D 100%); font-family:'Syne', serif;">CK</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-white text-sm font-semibold">The Copper Kettle</span>
                  <span class="text-white/30 text-xs">&lt;events@copperkettle.com&gt;</span>
                </div>
                <div class="text-white/80 text-sm mt-0.5 font-medium">Saturday only: Wagyu tasting menu (6 seats left)</div>
                <div class="text-white/30 text-xs mt-0.5">5 courses, 7pm, $125. We don't do this often.</div>
              </div>
              <span class="text-white/30 text-xs flex-shrink-0">4:12 PM</span>
            </div>

            <!-- Email Body (dark warm theme) -->
            <div style="background:#1C1917;">
              <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:600px; margin:0 auto;">

                <tr><td align="center" style="padding:36px 24px 20px 24px; font-family:'Syne', Georgia, serif;">
                  <div style="font-size:22px; font-weight:700; color:#FBBF24; letter-spacing:0.12em; text-transform:uppercase;">The Copper Kettle</div>
                  <div style="font-size:11px; color:#A8A29E; letter-spacing:0.3em; margin-top:4px; text-transform:uppercase;">Est. 2018 · Salt Lake City</div>
                </td></tr>

                <tr><td style="padding:0 24px;">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background:linear-gradient(135deg, #7F1D1D 0%, #451A03 100%); border-radius:20px; border:1px solid #78350F;">
                    <tr><td align="center" style="padding:56px 32px; font-family:'Syne', Georgia, serif;">
                      <div style="display:inline-block; padding:6px 16px; border-radius:50px; background:rgba(251,191,36,0.12); border:1px solid rgba(251,191,36,0.3); font-family:'DM Sans', sans-serif; font-size:11px; font-weight:600; color:#FBBF24; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:20px;">One Night Only</div>
                      <h1 style="margin:0 0 10px 0; font-size:40px; line-height:1.1; color:#FEF3C7; font-weight:700; letter-spacing:-0.02em;">
                        Wagyu<br>Tasting Menu
                      </h1>
                      <div style="font-family:'DM Sans', sans-serif; font-size:14px; color:#FBBF24; letter-spacing:0.2em; text-transform:uppercase; margin-top:12px;">Sat, April 24 · 7pm · $125/guest</div>
                    </td></tr>
                  </table>
                </td></tr>

                <tr><td style="padding:32px 40px 8px 40px; font-family:'DM Sans', Helvetica, Arial, sans-serif;">
                  <div style="font-size:11px; font-weight:600; color:#FBBF24; text-transform:uppercase; letter-spacing:0.3em; margin-bottom:14px;">The Menu</div>

                  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="border-top:1px solid #292524;">
                    <tr><td style="padding:14px 0; border-bottom:1px solid #292524;">
                      <div style="font-family:'Syne', Georgia, serif; font-size:15px; color:#FEF3C7; font-weight:600;">01 · Amuse-bouche</div>
                      <div style="font-size:13px; color:#A8A29E; margin-top:3px;">Seared foie gras, fig compote, brioche crumb</div>
                    </td></tr>
                    <tr><td style="padding:14px 0; border-bottom:1px solid #292524;">
                      <div style="font-family:'Syne', Georgia, serif; font-size:15px; color:#FEF3C7; font-weight:600;">02 · First Course</div>
                      <div style="font-size:13px; color:#A8A29E; margin-top:3px;">Charred octopus, smoked paprika, black garlic</div>
                    </td></tr>
                    <tr><td style="padding:14px 0; border-bottom:1px solid #292524;">
                      <div style="font-family:'Syne', Georgia, serif; font-size:15px; color:#FEF3C7; font-weight:600;">03 · Main Feature</div>
                      <div style="font-size:13px; color:#A8A29E; margin-top:3px;">A5 Wagyu, bone marrow butter, black truffle jus</div>
                    </td></tr>
                    <tr><td style="padding:14px 0; border-bottom:1px solid #292524;">
                      <div style="font-family:'Syne', Georgia, serif; font-size:15px; color:#FEF3C7; font-weight:600;">04 · Cheese</div>
                      <div style="font-size:13px; color:#A8A29E; margin-top:3px;">Artisan selection, local honeycomb, aged balsamic</div>
                    </td></tr>
                    <tr><td style="padding:14px 0;">
                      <div style="font-family:'Syne', Georgia, serif; font-size:15px; color:#FEF3C7; font-weight:600;">05 · Dessert</div>
                      <div style="font-size:13px; color:#A8A29E; margin-top:3px;">Dark chocolate soufflé, espresso crème anglaise</div>
                    </td></tr>
                  </table>
                </td></tr>

                <tr><td align="center" style="padding:28px 32px 16px 32px;">
                  <div style="display:inline-block; padding:6px 14px; border-radius:8px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); font-family:'DM Sans', sans-serif; font-size:12px; font-weight:600; color:#FCA5A5; letter-spacing:0.05em; margin-bottom:18px;">● 6 seats left of 24</div>
                  <br>
                  <table border="0" cellpadding="0" cellspacing="0" style="display:inline-block;">
                    <tr><td bgcolor="#FBBF24" style="background-color:#FBBF24; border-radius:10px;">
                      <a href="#" style="display:block; padding:16px 44px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:15px; font-weight:700; color:#1C1917; text-decoration:none; background:linear-gradient(135deg, #FBBF24 0%, #D97706 100%); border-radius:10px; letter-spacing:0.02em;">Reserve My Table</a>
                    </td></tr>
                  </table>
                </td></tr>

                <tr><td align="center" style="padding:24px 32px 36px 32px; font-family:'DM Sans', Helvetica, Arial, sans-serif; font-size:11px; color:#78716C; line-height:1.7;">
                  The Copper Kettle · 218 S Main, Salt Lake City<br>
                  <a href="#" style="color:#FBBF24; text-decoration:none;">View in browser</a> · <a href="#" style="color:#78716C; text-decoration:none;">Unsubscribe</a>
