        <!-- EMAIL MOCKUP 3: Med Spa Welcome -->
        <div class="reveal w-full max-w-[680px]">
          <div class="flex items-center justify-between mb-3 px-1">
            <span class="text-white/30 text-xs font-medium tracking-wide uppercase">Med Spa · Welcome Sequence</span>
            <span class="inline-flex items-center gap-1.5 text-[11px] text-white/40">
              <div class="w-1.5 h-1.5 rounded-full bg-rose-300"></div>
              Automation
            </span>
          </div>

          <div class="glass-interactive rounded-2xl overflow-hidden">
            <!-- Inbox Chrome -->
            <div class="flex items-start gap-3 p-4 border-b border-white/5 bg-white/[0.02]">
              <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center font-semibold text-white text-sm" style="background:linear-gradient(135deg, #D4A574 0%, #A16248 100%); font-family:'Syne', serif;">LV</div>
