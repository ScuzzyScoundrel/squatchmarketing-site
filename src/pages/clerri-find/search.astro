  { slug: 'irvington-family', name: 'Irvington Family Dental', initials: 'IF', neighborhood: 'Irvington', distance: 6.3, specialty: ['general','pedo'], languages: ['EN'], rating: 4.7, reviews: 612, price: 175, family: true, senior: true, financing: false, accepting: true, weekends: false, featured: false, tags: ['General','Pediatric'] },
  { slug: 'crossroads-perio', name: 'Crossroads Periodontics', initials: 'CP', neighborhood: 'Carmel', distance: 4.0, specialty: ['perio'], languages: ['EN'], rating: 4.8, reviews: 187, price: 329, family: false, senior: true, financing: true, accepting: false, weekends: false, featured: false, tags: ['Periodontics','Implants'] },
  { slug: 'midtown-dental-arts', name: 'Midtown Dental Arts', initials: 'MA', neighborhood: 'Midtown', distance: 2.5, specialty: ['general','cosmetic'], languages: ['EN','ES'], rating: 4.6, reviews: 489, price: 209, family: true, senior: false, financing: true, accepting: true, weekends: true, featured: false, tags: ['General','Cosmetic','Family'] },
