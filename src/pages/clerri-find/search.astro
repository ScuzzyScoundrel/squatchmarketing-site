const practices = [
  { slug: 'wells-family-dental', name: 'Wells Family Dental', initials: 'WD', neighborhood: 'Downtown Indianapolis', distance: 0.8, specialty: ['general','pedo'], languages: ['EN','ES'], rating: 4.9, reviews: 1247, price: 189, family: true, senior: true, financing: true, accepting: true, weekends: true, featured: true, tags: ['General','Pediatric','Cosmetic'] },
  { slug: 'circle-city-dental', name: 'Circle City Dental', initials: 'CD', neighborhood: 'Mass Ave', distance: 1.4, specialty: ['general'], languages: ['EN'], rating: 4.7, reviews: 893, price: 165, family: false, senior: true, financing: false, accepting: true, weekends: false, featured: false, tags: ['General','Cosmetic'] },
  { slug: 'indiana-orthodontics', name: 'Indiana Orthodontics Group', initials: 'IO', neighborhood: 'Broad Ripple', distance: 2.1, specialty: ['ortho'], languages: ['EN','ES'], rating: 4.8, reviews: 562, price: 399, family: false, senior: false, financing: true, accepting: true, weekends: true, featured: false, tags: ['Orthodontics','Adults + Teens'] },
