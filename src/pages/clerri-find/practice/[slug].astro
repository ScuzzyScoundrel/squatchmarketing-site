---
import ClerriFindLayout from '../../../layouts/ClerriFindLayout.astro';

export function getStaticPaths() {
  const practices = [
    { slug: 'wells-family-dental', name: 'Wells Family Dental', initials: 'WD', neighborhood: 'Downtown Indianapolis', address: '142 N Pennsylvania St, Indianapolis, IN 46204', phone: '(317) 555-0142', founded: 2008, owner: 'Dr. Brett Wells, DDS', members: '3,200+', rating: 4.9, reviews: 1247, languages: ['English', 'Español'], hours: { mtu: '7am-6pm', wt: '7am-6pm', f: '7am-2pm', s: '8am-1pm', su: 'Closed' }, accepting: 'Yes — usually within 1 week', plans: [ { tier: 'Individual', price: 189, featured: false, benefits: ['2 cleanings + exams/year', '2 sets of bitewing X-rays', '20% off all other services', 'No deductibles, no waiting'] }, { tier: 'Family of 4', price: 399, featured: true, label: 'Save $357', benefits: ['Best value vs. individual plans', 'All Individual benefits × 4', 'Free fluoride treatments for kids', 'Sibling cleaning bonus'] }, { tier: 'Senior (65+)', price: 159, featured: false, benefits: ['All Individual benefits', 'Discount on dentures + partials', 'Senior-specific cleaning protocols'] } ], services: ['General dentistry', 'Pediatric dentistry', 'Cosmetic dentistry', 'Crowns + bridges', 'Implants', 'Root canals', 'Whitening', 'Sealants'], story: 'Wells Family Dental has served the Indianapolis community for 17 years. Founded by Dr. Brett Wells, the practice focuses on long-term patient relationships, transparent pricing, and access to care for uninsured families. The practice was an early adopter of membership-plan-based care and now serves over 3,200 members.', perks: ['Same-day emergency appointments', 'Priority booking for members', 'Birthday offer (free whitening)', 'Sunbit financing on procedures over $500'] },
    { slug: 'circle-city-dental', name: 'Circle City Dental', initials: 'CD', neighborhood: 'Mass Ave', address: '425 Massachusetts Ave, Indianapolis, IN 46204', phone: '(317) 555-0425', founded: 2014, owner: 'Dr. Sarah Park, DDS', members: '1,800+', rating: 4.7, reviews: 893, languages: ['English'], hours: { mtu: '8am-5pm', wt: '8am-5pm', f: '8am-3pm', s: 'Closed', su: 'Closed' }, accepting: 'Yes — 2-3 week wait', plans: [ { tier: 'Individual', price: 165, featured: false, benefits: ['2 cleanings + exams/year', '15% off other services', 'No deductibles'] }, { tier: 'Senior (65+)', price: 129, featured: false, benefits: ['All Individual benefits', 'Discount on dentures'] } ], services: ['General dentistry', 'Cosmetic dentistry', 'Crowns + veneers', 'Whitening'], story: 'A modern downtown practice focused on adult general and cosmetic dentistry. Dr. Park opened Circle City Dental in 2014 after 8 years at a large group practice. The team specializes in a calmer, less-rushed patient experience.', perks: ['Saturday emergency line', 'Online member portal', 'Member-only whitening special twice yearly'] },
